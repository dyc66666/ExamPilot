/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 28rpx;
  color: #1a1a1a;
  background-color: #F5F5F5;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

/* 通用按钮 */
.btn-primary {
  background: #4F46E5;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}
.btn-primary:active {
  background: #4338CA;
}
