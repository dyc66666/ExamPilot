.assistant-page {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  min-height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #FDFBFF 0%, #FAF8FF 50%, #F6F4FC 100%);
}

/* ===== 三色交融装饰 ===== */
.tri-color-blobs {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 560rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.blob {
  position: absolute;
  border-radius: 50%;
}

.blob--blue {
  top: -170rpx;
  left: -50rpx;
  width: 470rpx;
  height: 420rpx;
  background: rgba(120, 180, 255, 0.15);
}

.blob--blue1 {
  top: -200rpx;
  right: -290rpx;
  width: 700rpx;
  height: 480rpx;
  background: rgba(120, 180, 255, 0.15);
}


.assistant-bg {
  position: absolute;
  top: 0;
  left: 0;
  z-index: -1;
  width: 100%;
  pointer-events: none;
  opacity: 0.12;
}

/* ===== 顶部导航（在装饰层之上）===== */
.assistant-navbar {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 130rpx 24rpx 24rpx;
}

.assistant-nav-brand {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.assistant-nav-title {
  display: block;
  color: var(--text-primary);
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.assistant-nav-subtitle {
  display: block;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.4;
}

/* 导航栏右侧新建对话按钮 */
/* ===== 主卡片（含IP角色和快捷操作）===== */
.main-card {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  margin: 0 16rpx;
  padding: 24rpx 220rpx 20rpx 24rpx; /* 右侧大留白给角色 */
  border-radius: var(--radius-card);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: var(--shadow-card);
  overflow: visible;
}

.main-card-left {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.ai-icon {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, var(--primary) 0%, #3A5FCC 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.main-card-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.main-card-title {
  display: block;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
}

.main-card-desc {
  display: block;
  color: var(--text-secondary);
  font-size: 22rpx;
  line-height: 1.45;
}

/* 主卡片右侧 IP 角色 — 浮出卡片右上方，带柔和底部阴影 */
.main-mascot {
  position: absolute;
  right: -8rpx;
  top: -44rpx;
  width: 248rpx;
  height: 268rpx;
  pointer-events: none;
  filter:
    drop-shadow(0 16rpx 40rpx rgba(100, 120, 180, 0.22))
    drop-shadow(0 4rpx 12rpx rgba(78, 91, 255, 0.14));
}

/* 快捷操作 chips */
.main-card .quick-actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 10rpx;
  margin-top: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.quick-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #EEF3FF;
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 500;
  line-height: 60rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

.quick-chip--muted {
  background: #F2F4F8;
  color: var(--text-secondary);
}

/* ===== 猜你想问 ===== */
.guess-section {
  flex: 0 0 auto;
  margin: 20rpx 16rpx 0;
  padding: 22rpx;
  border-radius: var(--radius-card);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: var(--shadow-card);
}

.guess-title {
  display: block;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.guess-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.guess-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 2rpx solid #F2F4F8;
}

.guess-item:last-child {
  border-bottom: none;
}

.guess-dot {
  flex: 0 0 auto;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--primary);
  opacity: 0.6;
}

.guess-text {
  flex: 1;
  min-width: 0;
  display: block;
  color: var(--text-primary);
  font-size: 26rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guess-arrow {
  flex: 0 0 auto;
  color: #C7C9CC;
  font-size: 32rpx;
  font-weight: 300;
}

/* ===== 聊天区域 ===== */
.chat-panel {
  flex: 1 1 auto;
  min-height: 0;
  margin: 16rpx 16rpx 0;
  overflow-y: auto;
}

.chat-content {
  display: flex;
  min-height: 100%;
  flex-direction: column;
  justify-content: flex-end;
  padding-bottom: 20rpx;
}

.message-row {
  display: flex;
  margin-bottom: 20rpx;
}

.message-row--assistant {
  justify-content: flex-start;
}

.message-row--user {
  justify-content: flex-end;
}

.message-bubble {
  max-width: 86%;
  padding: 22rpx 24rpx;
  border: 2rpx solid rgba(232, 236, 243, 0.94);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: var(--shadow-card);
}

.message-row--user .message-bubble {
  border-color: var(--primary);
  background: var(--primary);
  color: #FFFFFF;
}

/* AI 思考中脉冲动画 */
.message-bubble--loading {
  opacity: 0.7;
}

.loading-text {
  animation: pulse-dot 1.4s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 1; }
}

.message-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
}

.message-files {
  display: grid;
  gap: 10rpx;
  margin-top: 16rpx;
}

.message-file {
  padding: 12rpx 16rpx;
  border-radius: 16rpx;
  background: #F4F7FF;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.result-card {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #F7F9FE;
}

.result-title {
  display: block;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.result-desc {
  display: block;
  margin: 8rpx 0 18rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.5;
}

/* ===== 底部输入栏 ===== */
.composer-area {
  flex: 0 0 auto;
  margin: 16rpx 20rpx 36rpx;
}

.attachment-strip {
  width: 100%;
  margin-bottom: 10rpx;
  white-space: nowrap;
}

.attachment-list {
  display: inline-flex;
  gap: 10rpx;
  max-width: 100%;
}

.attachment-chip {
  display: inline-flex;
  align-items: center;
  max-width: 360rpx;
  height: 58rpx;
  padding: 0 8rpx 0 18rpx;
  border: 2rpx solid #DDE6FF;
  border-radius: 12rpx;
  background: #F4F7FF;
}

.attachment-name {
  max-width: 280rpx;
  overflow: hidden;
  color: var(--text-primary);
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attachment-remove {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  margin-left: 6rpx;
  padding: 0;
  border: 0;
  background: transparent;
  color: #8A94A6;
  font-size: 30rpx;
  line-height: 1;
}

.attachment-remove::after {
  border: 0;
}

.composer-bar {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0;
  padding: 16rpx 20rpx;
  border: 2rpx solid var(--border);
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}

.add-btn {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: #F2F4F8;
  color: var(--text-primary);
  font-size: 36rpx;
  font-weight: 400;
  line-height: 1;
}

.add-btn::after {
  border: 0;
}

.composer-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0;
  border: none;
  background: transparent;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 64rpx;
}

.composer-input::-webkit-input-placeholder {
  color: var(--text-secondary);
}

.send-btn {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: var(--primary);
  color: #FFFFFF;
}

.send-btn::after {
  border: 0;
}

.send-icon {
  font-size: 32rpx;
  font-weight: 700;
}

/* ===== 题库选择弹窗（居中） ===== */
.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(8rpx);
}

.center-panel {
  width: 520rpx;
  max-height: 70vh;
  overflow-y: auto;
  padding: 32rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.15);
}

.center-title {
  display: block;
  margin-bottom: 24rpx;
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.center-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.center-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: #F7F8FA;
}

.center-item--active {
  background: #EEF3FF;
  border: 2rpx solid var(--primary);
}

.center-color {
  flex: 0 0 auto;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

.center-name {
  flex: 1;
  min-width: 0;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 500;
}

.center-check {
  flex: 0 0 auto;
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 700;
}

.center-empty {
  padding: 40rpx 0;
  text-align: center;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.main-card {
  padding-right: 220rpx;
}

.main-mascot {
  z-index: 99;
  right: 8rpx;
  top: 6rpx;
  width: 226rpx;
  height: 214rpx;
  border-radius: 28rpx;
  overflow: visible;
}
