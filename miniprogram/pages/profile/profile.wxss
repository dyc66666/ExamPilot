/* ===== 个人中心 — 参考设计稿重写 ===== */

.tri-color-blobs {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 560rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}
.profile-page {
  position: relative;
  background: linear-gradient(180deg, #FDFBFF 0%, #F8F6FC 50%, #F4F2FF 100%);
  min-height: 100vh;
}

/* ===== 三色交融装饰 ===== */
.tri-color-blobs {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 560rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.blob {
  position: absolute;
  border-radius: 50%;
}

.blob--blue {
  top: -170rpx;
  left: -50rpx;
  width: 470rpx;
  height: 420rpx;
  background: rgba(120, 180, 255, 0.15);
}

.blob--blue1 {
  top: -200rpx;
  right: -290rpx;
  width: 700rpx;
  height: 480rpx;
  background: rgba(120, 180, 255, 0.15);
}

/* ===== 顶部个人信息 ===== */
.profile-hero {
  position: relative;
  z-index: 10;
  height: 396rpx;
  margin: 0 24rpx;
}

.avatar-wrap {
  position: absolute;
  left: 28rpx;
  top: 144rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 178rpx;
  height: 178rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #E8E3FF, #DDD6FF);
  border: 0;
  box-shadow: 0 16rpx 40rpx rgba(88, 103, 170, .12);
}

.avatar-button { margin: 0; padding: 0; border: 0; }
.avatar-button::after { border: 0; }

.avatar { width: 100%; height: 100%; }

.pf-info {
  position: absolute;
  left: 244rpx;
  top: 178rpx;
  z-index: 4;
  width: 250rpx;
  min-width: 0;
}

.pf-name {
  display: block;
  color: #111219;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.12;
}

.pf-phone {
  display: block;
  margin-top: 20rpx;
  color: #6F7488;
  font-size: 30rpx;
  line-height: 1.1;
}

.pf-mascot--hero {
  position: absolute;
  right: -20rpx;
  top: 150rpx;
  width: 260rpx;
  height: 262rpx;
  pointer-events: none;
  filter: drop-shadow(0 18rpx 24rpx rgba(90, 104, 160, .50));
}

/* ===== VIP 区域（吉祥物坐落其上）===== */
.vip-section {
  position: relative;
  z-index: 2;
  margin-top: -24rpx;
}

.vip-banner {
  position: relative;
  display: flex;
  align-items: center;
  margin: 0 24rpx;
  height: 70rpx;
  padding: 0 30rpx 50rpx;
  box-shadow: 0 12rpx 34rpx rgba(122, 112, 232, .18);
}

/* 背景层：SVG 负责完整轮廓，贝塞尔曲线末端水平收尾 */
.vip-bg-wrap {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  margin-top:-30rpx;
}

.vip-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-size: 100% 100%;
  background-image: url("data:image/svg+xml;base64,");
}
.vip-left {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
}

.vip-label {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
.vip-divider {
  margin: 0 15rpx;
  color: rgba(255, 255, 255, .58);
  font-size: 32rpx;
  font-weight: 400;
}
.vip-days {
  color: rgba(255, 255, 255, .86);
  font-size: 31rpx;
  font-weight: 400;
}

/* ===== 统计卡片 ===== */
.stats-card {
  position: relative;
  display: flex;
  align-items: center;
  margin: -22rpx 24rpx 0rpx 24rpx;
  padding: 32rpx 16rpx;
  border-radius: 22rpx 22rpx 22rpx 22rpx;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(100, 80, 200, .06);
  z-index:10;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  color: #1A1A2E;
  font-size: 44rpx;
  font-weight: 800;
}

.stat-label {
  color: #9B9BAD;
  font-size: 23rpx;
}

.stat-divider {
  width: 2rpx;
  height: 52rpx;
  background: #EEEAF5;
  flex-shrink: 0;
}

/* ===== 区块通用 ===== */
.section-block {
  margin: 24rpx 24rpx 0;
  padding: 28rpx 24rpx;
  border-radius: 22rpx;
  background: #fff;
  box-shadow: 0 2rpx 14rpx rgba(100, 80, 200, .05);
}

.section-block-footer {
  padding:10rpx 24rpx !important;
}

.section-title {
  display: block;
  color: #1A1A2E;
  font-size: 31rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

/* ===== 我的学习 — 四宫格（图标和参考图一致）===== */
.learn-grid {
  display: flex;
  justify-content: space-around;
}

.learn-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
}

.learn-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
}

.learn-text {
  color: #55586A;
  font-size: 24rpx;
  text-align: center;
}

/* ===== 设置菜单列表（图标颜色和参考图一致）===== */
.menu-list { display: flex; flex-direction: column; }

.menu-row {
  display: flex;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 2rpx solid #F3F2F8;
}
.menu-row:last-child { border-bottom: none; }

.menu-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
}

.menu-ico { font-size: 26rpx; }

/* 个人信息 */
.menu-icon--user   { }
/* 账号与设置 */
.menu-icon--lock   { }
/* 冲刺计划 */
.menu-icon--support{ }
/* 重置数据 */
.menu-icon--logout { }

.menu-txt {
  flex: 1;
  margin-left: 20rpx;
  color: #2D2D3A;
  font-size: 29rpx;
  font-weight: 500;
}

.menu-arrow {
  color: #C0C2CC;
  font-size: 38rpx;
  font-weight: 300;
}

/* ===== 编辑弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(0, 0, 0, .35);
  backdrop-filter: blur(8rpx);
}

.edit-panel {
  width: 100%;
  max-height: 82vh;
  overflow-y: auto;
  padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #fff;
  box-shadow: 0 -8rpx 48rpx rgba(0, 0, 0, .12);
}

.edit-panel__title {
  display: block;
  margin-bottom: 32rpx;
  color: #1A1A2E;
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
}

.efield { margin-bottom: 24rpx; }
.efield__label {
  display: block;
  margin-bottom: 10rpx;
  color: #55586A;
  font-size: 26rpx;
  font-weight: 600;
}
.efield__input {
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #EBEAFA;
  border-radius: 20rpx;
  background: #FBFAFF;
  color: #1A1A2E;
  font-size: 28rpx;
}
.efield__input::placeholder { color: #C0C2CC; }

.edit-btns {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 36rpx;
}

.ebtn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.ebtn--ghost {
  background: #F2F1F8;
  color: #66687A;
}

.ebtn--primary {
  background: linear-gradient(135deg, #7C5CFC, #9B6DFF);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(124, 92, 252, .30);
}
