<view class="page page--tab profile-page">
  <view class="tri-color-blobs">
    <view class="blob blob--blue"></view>
    <view class="blob blob--blue1"></view>
  </view>
  <view class="profile-hero">
    <button class="avatar-wrap avatar-button" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image class="avatar" src="{{user.avatar}}" mode="aspectFill" />
    </button>
    <view class="pf-info">
      <text class="pf-name">{{user.name}}</text>
      <text class="pf-phone">{{user.phone}}</text>
    </view>
    <image class="pf-mascot pf-mascot--hero" src="/images/mascot-transparent.png" mode="aspectFit" />
  </view>

  <view class="vip-section">
    <view class="vip-banner">
      <view class="vip-bg-wrap">
        <view class="vip-bg"></view>
      </view>
      <view class="vip-left">
        <text class="vip-label">{{user.identity}}</text>
        <text class="vip-divider">|</text>
        <text class="vip-days">{{user.grade}}</text>
      </view>
    </view>

    <!-- 统计数据行 -->
    <view class="stats-card">
    <view class="stat-item" bindtap="goToImport">
      <text class="stat-num">{{stats.totalQuestions}}</text>
      <text class="stat-label">题目总量</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="goToErrors">
      <text class="stat-num">{{stats.wrongCount}}</text>
      <text class="stat-label">错题数量</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.accuracy}}%</text>
      <text class="stat-label">掌握率</text>
    </view>
  </view>
  </view>

  <!-- 我的学习 -->
  <view class="section-block">
    <text class="section-title">我的学习</text>
    <view class="learn-grid">
      <view class="learn-item" bindtap="goToImport">
        <image class="learn-icon learn-icon--bank" src="/images/icon-bank.png" mode="aspectFit" />
        <text class="learn-text">专属题库</text>
      </view>
      <view class="learn-item" bindtap="goToErrors">
        <image class="learn-icon learn-icon--error" src="/images/icon-error.png" mode="aspectFit" />
        <text class="learn-text">专属错题本</text>
      </view>
      <view class="learn-item">
        <image class="learn-icon learn-icon--report" src="/images/icon-report.png" mode="aspectFit" />
        <text class="learn-text">学习报告</text>
      </view>
      <view class="learn-item">
        <image class="learn-icon learn-icon--fav" src="/images/icon-fav.png" mode="aspectFit" />
        <text class="learn-text">收藏题目</text>
      </view>
    </view>
  </view>

  <!-- 设置菜单列表 -->
  <view class="section-block section-block-footer">
    <view class="menu-list">
      <view class="menu-row" bindtap="toggleEdit">
        <view class="menu-icon-wrap menu-icon--user">
          <image class="menu-icon" src="/images/people.png" mode="aspectFit" />
        </view>
        <text class="menu-txt">个人信息</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="toggleEdit">
        <view class="menu-icon-wrap menu-icon--lock">
          <image class="menu-icon" src="/images/lock.png" mode="aspectFit" />
        </view>
        <text class="menu-txt">账号密码</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="goToSprint">
        <view class="menu-icon-wrap menu-icon--support">
          <image class="menu-icon" src="/images/headset.png" mode="aspectFit" />
        </view>
        <text class="menu-txt">联系客服</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-row" bindtap="clearAllData">
        <view class="menu-icon-wrap menu-icon--logout">
          <image class="menu-icon" src="/images/power.png" mode="aspectFit" />
        </view>
        <text class="menu-txt">退出登录</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 编辑个人信息弹窗 -->
  <view class="modal-mask" wx:if="{{isEditing}}" catchtap="cancelEdit">
    <view class="modal-panel" catchtap="noop">
      <text class="modal-title">编辑个人信息</text>
      
      <view class="field">
        <text class="field-label">昵称</text>
        <input class="field-input" value="{{draftUser.name}}" placeholder="你的称呼" bindinput="onNameInput" />
      </view>
      <view class="field">
        <text class="field-label">身份标签</text>
        <input class="field-input" value="{{draftUser.identity}}" placeholder="大学生 / 考研党 / 高中生" bindinput="onIdentityInput" />
      </view>
      <view class="field">
        <text class="field-label">年级</text>
        <input class="field-input" value="{{draftUser.grade}}" placeholder="大一 / 大二 / ..." bindinput="onGradeInput" />
      </view>
      <view class="field">
        <text class="field-label">专业方向</text>
        <input class="field-input" value="{{draftUser.major}}" placeholder="数学、计算机、经济学..." bindinput="onMajorInput" />
      </view>
      <view class="field">
        <text class="field-label">目标考试</text>
        <input class="field-input" value="{{draftUser.targetExam}}" placeholder="期末考试 / 四六级 / 考研..." bindinput="onTargetInput" />
      </view>

      <view class="modal-btns">
        <view class="btn btn--cancel" bindtap="cancelEdit">取消</view>
        <view class="btn btn--save" bindtap="saveProfile">保存</view>
      </view>
    </view>
  </view>
</view>
