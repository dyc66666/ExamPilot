.quiz-page { background:var(--background); }
.start-visual { display:flex; justify-content:center; padding:32rpx 0 24rpx; }
.start-orb { display:flex; align-items:center; justify-content:center; width:128rpx; height:128rpx; border-radius:999rpx; background:rgba(52,199,89,.16); color:var(--success); font-size:64rpx; font-weight:700; }
.start-title { display:block; color:var(--text-primary); font-size:40rpx; font-weight:600; text-align:center; }
.start-desc { display:block; margin:16rpx auto 32rpx; color:var(--text-secondary); font-size:28rpx; line-height:1.6; text-align:center; }
.start-point { display:flex; align-items:center; margin-bottom:16rpx; padding:20rpx; border-radius:24rpx; background:#F7F9FE; }
.point-index { display:flex; align-items:center; justify-content:center; width:36rpx; height:36rpx; margin-right:14rpx; border-radius:999rpx; background:#EEF3FF; color:var(--primary); font-size:22rpx; font-weight:700; }
.point-text { color:var(--text-secondary); font-size:26rpx; }
.secondary-link { margin-top:24rpx; color:var(--primary); font-size:28rpx; text-align:center; }
.quiz-meta { display:flex; align-items:center; justify-content:space-between; margin-bottom:20rpx; }
.question-stem { display:block; margin-top:28rpx; color:var(--text-primary); font-size:32rpx; font-weight:600; line-height:1.65; }
.options-list { display:grid; gap:16rpx; margin-top:28rpx; }
.option-item { display:grid; grid-template-columns:28rpx 40rpx 1fr; align-items:center; min-height:88rpx; padding:0 24rpx; border:2rpx solid var(--border); border-radius:16rpx; background:#fff; }
.option-radio { width:16rpx; height:16rpx; border:2rpx solid #B9C0CC; border-radius:999rpx; }
.option-label { color:var(--text-secondary); font-size:26rpx; font-weight:600; }
.option-text { color:var(--text-primary); font-size:28rpx; font-weight:500; }
.option-item--selected { border-color:#DCE6FF; background:#EEF3FF; }
.option-item--selected .option-radio { border-color:var(--primary); background:var(--primary); }
.option-item--correct { border-color:rgba(52,199,89,.36); background:rgba(52,199,89,.10); }
.option-item--wrong { border-color:rgba(255,69,58,.36); background:rgba(255,69,58,.08); }
.confidence-section { margin-top:32rpx; }
.confidence-title { display:block; margin-bottom:16rpx; color:var(--text-secondary); font-size:28rpx; }
.confidence-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12rpx; }
.confidence-chip { height:72rpx; border:2rpx solid var(--border); border-radius:18rpx; background:#fff; color:var(--text-secondary); font-size:26rpx; line-height:72rpx; text-align:center; }
.confidence-chip--active { border-color:var(--primary); background:var(--primary); color:#fff; }
.answer-panel { margin-top:32rpx; }
.answer-result { padding:24rpx; border-radius:24rpx; }
.answer-result--correct { background:rgba(52,199,89,.10); }
.answer-result--wrong { background:rgba(255,69,58,.08); }
.answer-result__title { display:block; color:var(--text-primary); font-size:30rpx; font-weight:600; }
.answer-result__desc { display:block; margin-top:6rpx; color:var(--text-secondary); font-size:26rpx; }
.explanation-box { margin-top:20rpx; padding:24rpx; border-radius:24rpx; background:#F7F9FE; }
.explanation-label { display:block; color:var(--primary); font-size:26rpx; font-weight:600; }
.explanation-text { display:block; margin-top:10rpx; color:var(--text-secondary); font-size:26rpx; line-height:1.6; }
.quiz-actions { display:grid; grid-template-columns:1fr 1.4fr; gap:16rpx; margin-top:40rpx; }
