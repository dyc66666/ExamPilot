<view class="page quiz-page">
  <view wx:if="{{!isQuizStarted}}">
    <ui-navbar title="学习" subtitle="{{currentBank}}" back="{{true}}" bind:back="goBack" />
    <ui-card>
      <view class="start-visual"><view class="start-orb">✓</view></view>
      <text class="start-title">{{currentBank}} · 共{{bankQuestionCount}}题</text>
      <text class="start-desc">选择选项后提交，系统自动判断对错并记录</text>
      <text class="duplicate-audit" wx:if="{{duplicateQuestionCount > 0}}">检测到 {{duplicateQuestionCount}} 道重复项，建议返回题库核对</text>
      <view class="sort-toggle" bindtap="toggleSortMode">
        <text>答题顺序：{{sortMode === 'sequential' ? '顺序' : '随机'}}</text>
        <text class="sort-hint">点击切换</text>
      </view>
      <block wx:if="{{hasProgress}}">
        <ui-button variant="primary" block="{{true}}" bind:tap="resumeQuiz">继续测评</ui-button>
        <view class="secondary-link" bindtap="startQuiz">重新开始</view>
      </block>
      <block wx:else>
        <ui-button variant="primary" block="{{true}}" disabled="{{questions.length === 0}}" bind:tap="startQuiz">
          {{questions.length === 0 ? '暂无题目，请先导入' : '开始测评'}}
        </ui-button>
        <view class="secondary-link" bindtap="goToImport" wx:if="{{questions.length === 0}}">去导入题库</view>
      </block>
    </ui-card>
  </view>

  <view class="quiz-body" wx:if="{{isQuizStarted && currentQuestion}}">
    <view class="quiz-hero">
      <view class="quiz-hero-bg quiz-hero-bg-a"></view>
      <view class="quiz-hero-bg quiz-hero-bg-b"></view>
      <view class="quiz-hero-nav">
        <view class="quiz-back" bindtap="goBack">‹</view>
        <view class="quiz-title-block">
          <text class="quiz-title">测评</text>
          <text class="quiz-progress-text">{{progressText}}</text>
        </view>
        <view class="quiz-nav-space"></view>
      </view>
      <image class="quiz-hero-mascot" src="{{mascotSrc}}" mode="aspectFit" bindtap="openMascotChat" />
      <view class="progress-track quiz-progress-track"><view class="progress-fill {{progressClass}}"></view></view>
      <view class="quiz-meta quiz-hero-meta">
        <text class="qtype-tag {{currentQuestion.qtype === '多选题' ? 'qtype-multi' : (currentQuestion.qtype === '主观题' ? 'qtype-subjective' : 'qtype-single')}}">{{currentQuestion.qtype}}</text>
        <text class="source-tag {{currentQuestion.sourceType === 'original' ? 'source-tag--original' : (currentQuestion.sourceType === 'rag' ? 'source-tag--rag' : 'source-tag--generated')}}" wx:if="{{currentQuestion.sourceLabel}}">{{currentQuestion.sourceLabel}}</text>
        <text class="answer-count" wx:if="{{currentQuestion.qtype !== '主观题'}}">{{currentQuestion.answer.length}}</text>
        <text class="quiz-master-btn" wx:if="{{!isSubmitted}}" bindtap="markAsMastered">✓ 已掌握，跳过</text>
      </view>
    </view>

    <view class="quiz-content" bindtouchstart="onQuestionTouchStart" bindtouchend="onQuestionTouchEnd">
      <view class="question-stem-row">
        <text class="question-number">{{currentIndex + 1}}.</text>
        <mp-html
          class="question-stem question-rich-text"
          content="{{currentQuestion.stemHtml}}"
          container-style="font-size:36rpx;font-weight:800;line-height:1.55;overflow-x:auto;"
          selectable="{{true}}"
        />
      </view>

      <view class="options-list" wx:if="{{currentQuestion.qtype !== '主观题'}}">
        <view wx:for="{{currentQuestion.optionItems}}" wx:key="label" wx:for-item="opt" wx:for-index="i"
          class="option-item {{opt._sel ? 'option-item--selected' : ''}} {{opt._correct ? 'option-item--correct' : ''}} {{opt._wrong ? 'option-item--wrong' : ''}}"
          bindtap="toggleAnswer" data-value="{{opt.label}}">
          <view class="opt-mark">{{currentQuestion.qtype === '多选题' ? (opt._sel ? '✓' : '') : ''}}</view>
          <text class="option-label">{{opt.label}}</text>
          <mp-html
            class="option-text option-rich-text"
            content="{{opt.html}}"
            container-style="color:{{opt._correct ? '#137A49' : (opt._wrong ? '#C93242' : (opt._sel ? '#FFFFFF' : '#101B4F'))}};font-size:31rpx;font-weight:500;line-height:1.45;overflow-x:auto;"
            selectable="{{true}}"
          />
        </view>
      </view>

      <view class="subjective-answer-wrap" wx:else>
        <textarea
          class="subjective-answer-input"
          value="{{currentQuestion.userAnswer}}"
          placeholder="在这里输入你的答案..."
          maxlength="-1"
          disabled="{{isSubmitted || subjectiveGrading}}"
          bindinput="onSubjectiveAnswerInput"
        />
        <text class="subjective-answer-hint" wx:if="{{!isSubmitted}}">AI 会结合参考答案判断正确性</text>
      </view>

      <view class="question-nav-row">
        <button class="question-nav-btn" disabled="{{currentIndex === 0}}" bindtap="previousQuestion">‹ 上一题</button>
        <text class="question-nav-hint">也可左右滑动</text>
        <button class="question-nav-btn" disabled="{{currentIndex + 1 >= questions.length}}" bindtap="nextQuestion">下一题 ›</button>
      </view>

      <view class="submit-row" wx:if="{{!isSubmitted}}">
        <button class="submit-btn" loading="{{subjectiveGrading}}" disabled="{{subjectiveGrading}}" bindtap="submitAnswer">{{subjectiveGrading ? 'AI批改中' : '提交答案'}}</button>
      </view>

      <view wx:if="{{isSubmitted}}" class="answer-panel">
        <view class="answer-result {{isCorrect ? 'answer-result--correct' : (currentQuestion.gradingVerdict === 'partial' ? 'answer-result--partial' : 'answer-result--wrong')}}">
          <text class="answer-result-title">{{isCorrect ? '回答正确' : (currentQuestion.gradingVerdict === 'partial' ? '基本正确' : '回答错误')}}</text>
          <text class="answer-result-desc" wx:if="{{currentQuestion.qtype !== '主观题'}}">正确答案：{{currentQuestion.answer}}</text>
          <text class="answer-result-desc" wx:else>AI 判断得分：{{currentQuestion.gradingScore}} / 100</text>
        </view>
        <view class="subjective-feedback" wx:if="{{currentQuestion.qtype === '主观题' && currentQuestion.gradingFeedback}}">
          <text class="explanation-label">AI 批改意见</text>
          <text class="subjective-feedback-text">{{currentQuestion.gradingFeedback}}</text>
        </view>
        <view class="subjective-reference" wx:if="{{currentQuestion.qtype === '主观题'}}">
          <text class="explanation-label">参考答案</text>
          <mp-html
            content="{{currentQuestion.answerHtml}}"
            container-style="color:#687086;font-size:26rpx;line-height:1.6;overflow-x:auto;"
            selectable="{{true}}"
          />
        </view>
        <view class="explanation-box" wx:if="{{!isCorrect || currentQuestion.explanation}}">
          <text class="explanation-label">解析</text>
          <text class="explanation-text" wx:if="{{explanationLoading}}">AI 正在生成解析...</text>
          <mp-html
            class="explanation-text explanation-rich-text"
            wx:else
            content="{{currentQuestion.explanationHtml || '暂无解析'}}"
            container-style="color:#687086;font-size:26rpx;line-height:1.6;overflow-x:auto;"
            selectable="{{true}}"
          />
        </view>
        <view class="next-btn" bindtap="nextQuestion">下一题</view>
      </view>
    </view>

    <view class="quiz-bottom" wx:if="{{!isSubmitted}}">
      <view class="bottom-btn bottom-btn--skip" bindtap="markAsDontKnow">不会，看答案</view>
    </view>

    <view class="mascot-chat-mask" wx:if="{{mascotChatVisible}}" bindtap="closeMascotChat">
      <view class="mascot-chat-panel {{mascotChatFullscreen ? 'mascot-chat-panel--full' : ''}}" style="height: {{mascotChatPanelHeight}}vh;" catchtap="noop">
        <view
          class="mascot-chat-handle"
          catchtouchstart="startMascotPanelDrag"
          catchtouchmove="dragMascotPanel"
          catchtouchend="endMascotPanelDrag"
          catchtouchcancel="endMascotPanelDrag"
        ></view>
        <view class="mascot-chat-head">
          <image class="mascot-chat-avatar" src="{{mascotSrc}}" mode="aspectFit" />
          <view class="mascot-chat-title-wrap">
            <text class="mascot-chat-title">AI 学习伙伴</text>
            <text class="mascot-chat-subtitle">正在陪你答题</text>
          </view>
          <view class="mascot-chat-tools">
            <view class="mascot-tool-btn mascot-tool-btn--min" bindtap="shrinkMascotChat" aria-label="缩小"></view>
            <view class="mascot-tool-btn mascot-tool-btn--max" bindtap="expandMascotChat" aria-label="放大"></view>
            <view class="mascot-tool-btn mascot-tool-btn--close" bindtap="closeMascotChat" aria-label="关闭"></view>
          </view>
        </view>
        <scroll-view class="mascot-chat-list" scroll-y="true" scroll-top="{{mascotChatScrollTop}}" scroll-with-animation="{{true}}">
          <view class="mascot-message-row mascot-message-row--{{item.role}}" wx:for="{{mascotChatMessages}}" wx:key="id">
            <view class="mascot-message-bubble {{item.loading ? 'mascot-message-bubble--loading' : ''}}">
              <text>{{item.loading ? '正在思考...' : item.content}}</text>
            </view>
          </view>
        </scroll-view>
        <view class="mascot-chat-actions">
          <text class="mascot-chat-chip" data-text="讲讲这题" bindtap="useMascotQuick">讲讲这题</text>
          <text class="mascot-chat-chip" data-text="给我提示" bindtap="useMascotQuick">给我提示</text>
        </view>
        <view class="mascot-composer">
          <input
            class="mascot-composer-input"
            value="{{mascotChatInput}}"
            placeholder="问我这道题..."
            confirm-type="send"
            bindinput="onMascotChatInput"
            bindconfirm="sendMascotChatFromInput"
          />
          <button class="mascot-send-btn" loading="{{mascotChatSending}}" disabled="{{mascotChatSending}}" bindtap="sendMascotChatFromInput">↑</button>
        </view>
      </view>
    </view>
  </view>
</view>
