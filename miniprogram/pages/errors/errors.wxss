.container { padding-bottom: 40rpx; }

.banner {
  background: linear-gradient(135deg, #EF4444, #DC2626);
  padding: 50rpx 40rpx; text-align: center;
}
.banner-num { font-size: 72rpx; font-weight: 700; color: #fff; display: block; }
.banner-label { font-size: 26rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 8rpx; }

.sprint-entry {
  display: flex; align-items: center;
  background: linear-gradient(135deg, #4F46E5, #7C3AED);
  border-radius: 16rpx; margin: 24rpx; padding: 32rpx;
  color: #fff;
}
.sprint-icon { font-size: 48rpx; margin-right: 20rpx; }
.sprint-info { flex: 1; }
.sprint-title { font-size: 30rpx; font-weight: 700; display: block; }
.sprint-desc { font-size: 24rpx; opacity: 0.8; display: block; margin-top: 6rpx; }
.sprint-arrow { font-size: 48rpx; opacity: 0.6; }

.empty { text-align: center; padding: 120rpx 0; }
.empty-icon { font-size: 100rpx; display: block; margin-bottom: 24rpx; }
.empty-title { font-size: 36rpx; font-weight: 700; display: block; }
.empty-desc { font-size: 26rpx; color: #999; display: block; margin-top: 12rpx; }

.card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin: 0 24rpx 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.group-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid #f0f0f0; }
.group-name { font-size: 30rpx; font-weight: 700; }
.group-count { font-size: 24rpx; color: #EF4444; background: #FEF2F2; padding: 6rpx 16rpx; border-radius: 8rpx; }

.group-question { padding: 20rpx 0; border-bottom: 1rpx dashed #f0f0f0; }
.group-question:last-child { border-bottom: none; }
.gq-header { display: flex; justify-content: space-between; margin-bottom: 10rpx; }
.gq-confidence { font-size: 22rpx; padding: 4rpx 10rpx; border-radius: 6rpx; }
.gq-confidence[data-type="sure"] { background: #FEF2F2; color: #EF4444; }
.gq-confidence[data-type="unsure"] { background: #FEF3C7; color: #D97706; }
.gq-confidence[data-type="guess"] { background: #F3F4F6; color: #6B7280; }
.gq-count { font-size: 22rpx; color: #999; }
.gq-stem { font-size: 28rpx; display: block; margin-bottom: 8rpx; }
.gq-answer { font-size: 24rpx; color: #10B981; display: block; margin-bottom: 4rpx; }
.gq-exp { font-size: 24rpx; color: #666; display: block; }

.bottom-bar { padding: 40rpx 24rpx; text-align: center; }
.btn-clear { background: none; border: 1rpx solid #ddd; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #999; }
