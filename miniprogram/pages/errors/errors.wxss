.errors-page { background:var(--background); }
.book-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24rpx; }
.book-title { display:block; color:var(--text-primary); font-size:40rpx; font-weight:700; }
.book-subtitle { display:block; margin-top:6rpx; color:var(--text-secondary); font-size:24rpx; }
.sprint-entry { display:flex; align-items:center; padding:28rpx; border:2rpx solid #DDE7FF; border-radius:var(--radius-card); background:#fff; box-shadow:var(--shadow-card); }
.sprint-entry__icon { display:flex; align-items:center; justify-content:center; width:72rpx; height:72rpx; border-radius:24rpx; background:#EEF3FF; color:var(--primary); font-size:32rpx; }
.sprint-entry__copy { flex:1; margin-left:20rpx; }
.sprint-entry__title { display:block; color:var(--text-primary); font-size:30rpx; font-weight:600; }
.sprint-entry__desc { display:block; margin-top:6rpx; color:var(--text-secondary); font-size:24rpx; }
.sprint-entry__arrow { color:#B4B8C2; font-size:46rpx; }
.empty-state { display:flex; flex-direction:column; align-items:center; padding:48rpx 0 16rpx; text-align:center; }
.empty-visual { display:flex; align-items:center; justify-content:center; width:112rpx; height:112rpx; border-radius:999rpx; background:rgba(52,199,89,.14); color:var(--success); font-size:56rpx; font-weight:700; }
.empty-title { display:block; margin-top:28rpx; color:var(--text-primary); font-size:36rpx; font-weight:600; }
.empty-desc { display:block; margin:12rpx 0 32rpx; color:var(--text-secondary); font-size:28rpx; line-height:1.6; }
.group-card { margin-bottom:24rpx; padding:32rpx; border:2rpx solid var(--border); border-radius:var(--radius-card); background:#fff; box-shadow:var(--shadow-card); }
.group-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16rpx; }
.group-name { color:var(--text-primary); font-size:32rpx; font-weight:600; }
.wrong-row { padding:24rpx 0; border-top:2rpx solid #F1F3F7; }
.wrong-row__top { display:flex; align-items:flex-start; justify-content:space-between; gap:16rpx; }
.wrong-title { flex:1; color:var(--text-primary); font-size:28rpx; font-weight:600; line-height:1.45; }
.wrong-date { color:var(--text-secondary); font-size:24rpx; }
.wrong-row__meta { display:flex; gap:12rpx; margin-top:12rpx; }
.wrong-label { padding:4rpx 12rpx; border-radius:999rpx; font-size:22rpx; font-weight:500; }
.wrong-label--error { background:rgba(255,69,58,.10); color:var(--error); }
.wrong-label--success { background:rgba(52,199,89,.12); color:var(--success); }
.wrong-answer { display:block; margin-top:12rpx; color:var(--text-secondary); font-size:26rpx; }
.bottom-action { margin-top:24rpx; }
