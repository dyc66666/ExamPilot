<view class="page page--tab errors-page">
  <ui-navbar title="错题本" subtitle="诊断薄弱点" />

  <ui-card compact="{{true}}">
    <view class="book-header">
      <view><text class="book-title">错题本</text><text class="book-subtitle">{{wrongQuestions.length}} 道题待巩固</text></view>
    </view>
    <ui-tabs items="{{filterTabs}}" active="{{activeFilter}}" bind:change="onFilterChange" />
  </ui-card>

  <view class="section-tight" wx:if="{{wrongQuestions.length > 0}}">
    <view class="sprint-entry" bindtap="startSprint">
      <view class="sprint-entry__icon">⚡</view>
      <view class="sprint-entry__copy"><text class="sprint-entry__title">消灭错题 · 冲刺模式</text><text class="sprint-entry__desc">按错因和知识点安排最短复习路径</text></view>
      <text class="sprint-entry__arrow">›</text>
    </view>
  </view>

  <view class="section-tight" wx:if="{{wrongQuestions.length === 0}}">
    <ui-card>
      <view class="empty-state">
        <view class="empty-visual">✓</view>
        <text class="empty-title">错题本为空</text>
        <text class="empty-desc">完成一次快速测评后，答错题目会自动进入这里。</text>
        <ui-button variant="primary" bind:tap="goToQuiz">开始测评</ui-button>
      </view>
    </ui-card>
  </view>

  <view class="section-tight" wx:if="{{groupedQuestions.length > 0}}">
    <view class="group-card" wx:for="{{groupedQuestions}}" wx:key="name">
      <view class="group-header"><text class="group-name">{{item.name}}</text><text class="tag tag--error">{{item.count}} 题</text></view>
      <view class="wrong-row" wx:for="{{item.questions}}" wx:key="id" wx:for-item="q">
        <view class="wrong-row__top"><text class="wrong-title">{{q.stem}}</text><text class="wrong-date">{{q.dateText}}</text></view>
        <view class="wrong-row__meta"><text class="wrong-label wrong-label--error">错因：{{q.confidenceText}}</text><text class="wrong-label wrong-label--success">错 {{q.wrongCount || 1}} 次</text></view>
        <text class="wrong-answer">{{q.type === 'subjective' ? '参考答案' : '答案'}}：{{q.answer}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-action" wx:if="{{wrongQuestions.length > 0}}">
    <view class="clear-btn" bindtap="clearErrors">清空错题本</view>
  </view>
</view>
