.home-page { background: var(--background); }
.hero-card { display:flex; align-items:flex-end; justify-content:space-between; min-height:216rpx; padding:28rpx; border-radius:32rpx; background:var(--primary); color:#fff; }
.hero-label,.hero-plan { display:block; font-size:24rpx; opacity:.88; }
.hero-days { display:flex; align-items:baseline; margin-top:8rpx; }
.hero-number { font-size:56rpx; font-weight:700; line-height:1; }
.hero-unit { margin-left:12rpx; font-size:28rpx; font-weight:500; }
.hero-plan { margin-top:24rpx; }
.hero-action { min-width:116rpx; height:48rpx; padding:0 20rpx; border-radius:999rpx; background:#fff; color:var(--primary); font-size:24rpx; font-weight:600; line-height:48rpx; text-align:center; }
.metric-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16rpx; }
.metric-label,.metric-caption { display:block; color:var(--text-secondary); font-size:24rpx; text-align:center; }
.metric-value { display:block; margin-top:8rpx; color:var(--text-primary); font-size:36rpx; font-weight:700; text-align:center; }
.knowledge-layout { display:flex; align-items:center; gap:32rpx; }
.donut { position:relative; width:168rpx; height:168rpx; flex:0 0 168rpx; border-radius:50%; background:conic-gradient(#4E7BFF 0 44%, #34C759 44% 62%, #FF9F0A 62% 82%, #D9DEE8 82% 100%); }
.donut-hole { position:absolute; top:40rpx; left:40rpx; width:88rpx; height:88rpx; border-radius:50%; background:#fff; }
.legend-list { flex:1; }
.legend-item { display:grid; grid-template-columns:18rpx 1fr auto; align-items:center; gap:12rpx; margin-bottom:16rpx; }
.legend-dot { width:12rpx; height:12rpx; border-radius:999rpx; }
.legend-dot--blue{background:var(--primary)} .legend-dot--green{background:var(--success)} .legend-dot--orange{background:var(--warning)} .legend-dot--gray{background:#D9DEE8}
.legend-label,.legend-value { font-size:24rpx; }
.legend-label { color:var(--text-secondary); }
.legend-value { color:var(--text-primary); font-weight:600; }
.feature-row { display:flex; align-items:center; padding:24rpx 0; }
.feature-copy { flex:1; margin-left:20rpx; }
.feature-title { display:block; color:var(--primary); font-size:28rpx; font-weight:600; }
.feature-desc { display:block; margin-top:8rpx; color:var(--text-secondary); font-size:24rpx; }
