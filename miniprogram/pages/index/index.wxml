<view class="container">
  <!-- 顶部标题区 -->
  <view class="header">
    <text class="logo">🎯</text>
    <text class="title">ExamPilot AI</text>
    <text class="subtitle">智能考试冲刺系统</text>
  </view>

  <!-- 数据概览卡片 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{stats.totalQuestions}}</text>
      <text class="stat-label">题库总数</text>
    </view>
    <view class="stat-card">
      <text class="stat-num green">{{stats.masteredCount}}</text>
      <text class="stat-label">已掌握</text>
    </view>
    <view class="stat-card">
      <text class="stat-num red">{{stats.wrongCount}}</text>
      <text class="stat-label">待攻克</text>
    </view>
    <view class="stat-card">
      <text class="stat-num blue">{{stats.accuracy}}%</text>
      <text class="stat-label">正确率</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="section">
    <text class="section-title">快捷操作</text>
    <view class="action-cards">
      <view class="action-card" bindtap="goToImport">
        <text class="action-icon">📥</text>
        <text class="action-title">导入题库</text>
        <text class="action-desc">PDF / 图片 / 文档导入</text>
      </view>
      <view class="action-card" bindtap="goToQuiz">
        <text class="action-icon">📝</text>
        <text class="action-title">快速测评</text>
        <text class="action-desc">智能诊断掌握程度</text>
      </view>
      <view class="action-card" bindtap="goToErrors">
        <text class="action-icon">📋</text>
        <text class="action-title">错题本</text>
        <text class="action-desc">精准复习查漏补缺</text>
      </view>
      <view class="action-card" bindtap="goToSprint">
        <text class="action-icon">🚀</text>
        <text class="action-title">冲刺模式</text>
        <text class="action-desc">消灭所有薄弱点</text>
      </view>
    </view>
  </view>

  <!-- 产品亮点 -->
  <view class="section">
    <text class="section-title">你的学习闭环</text>
    <view class="feature-list">
      <view class="feature-item">
        <text class="feature-dot">1</text>
        <text>导入资料 → AI自动结构化</text>
      </view>
      <view class="feature-item">
        <text class="feature-dot">2</text>
        <text>快速测评 → 发现知识盲区</text>
      </view>
      <view class="feature-item">
        <text class="feature-dot">3</text>
        <text>错题诊断 → 理解错因</text>
      </view>
      <view class="feature-item">
        <text class="feature-dot">4</text>
        <text>冲刺模式 → 最短路径攻克</text>
      </view>
    </view>
  </view>
</view>
