<view class="page page--tab home-page">
  <view class="home-navbar">
    <view class="home-brand">
      <text class="home-title">ExamPilot AI</text>
      <view class="brand-line">
        <text class="ai-chip">AI</text>
        <text class="home-subtitle">智能考试冲刺系统</text>
      </view>
    </view>
  </view>

  <view class="hero-panel">
    <image class="hero-bg" src="/images/home-hero-bg.png" mode="aspectFill" />
    <view class="hero-content">
      <text class="hero-label">距离考试还有</text>
      <view class="hero-days">
        <block wx:if="{{editingDays}}">
          <input
            class="hero-input-days"
            type="number"
            value="{{overview.daysLeft}}"
            focus="{{true}}"
            bindconfirm="onDaysBlur"
            bindblur="onDaysBlur"
            adjust-position="{{false}}"
          />
        </block>
        <block wx:else>
          <text class="hero-number {{overview.daysLeft <= 3 ? 'urgent' : ''}}" bindtap="editDaysTap">{{overview.daysLeft}}</text>
        </block>
        <text class="hero-unit">天</text>
      </view>
      <view class="hero-plan" bindtap="openBankPicker">
        <text>当前题库：</text>
        <text class="hero-bank-name-inline">{{currentBank || '未选择'}}</text>
        <text class="hero-down-arrow">▾</text>
      </view>
      <view class="hero-action" bindtap="goToQuiz">开始学习</view>
    </view>
  </view>

  <view class="section-tight">
    <view class="section-head">
      <text class="section-title">学习数据</text>
      <text class="section-link">详情 〉</text>
    </view>
    <view class="metric-grid">
      <view class="metric-card">
        <text class="metric-label">题库总量</text>
        <text class="metric-value">{{stats.totalQuestions}}</text>
        <text class="metric-caption">题</text>
      </view>
      <view class="metric-card">
        <text class="metric-label">掌握率</text>
        <text class="metric-value">{{stats.accuracy}}%</text>
        <text class="metric-caption">已掌握</text>
      </view>
      <view class="metric-card">
        <text class="metric-label">已消化</text>
        <text class="metric-value">{{stats.masteredCount}}</text>
        <text class="metric-caption">题</text>
      </view>
    </view>
  </view>

  <view class="knowledge-card">
    <text class="section-title">知识掌握分布</text>
    <view class="knowledge-layout">
      <view class="donut"><view class="donut-hole"></view></view>
      <view class="legend-list">
        <view class="legend-item"><text class="legend-dot legend-dot--blue"></text><text class="legend-label">已掌握</text><text class="legend-value">{{stats.masteredCount}}</text></view>
        <view class="legend-item"><text class="legend-dot legend-dot--green"></text><text class="legend-label">模糊掌握</text><text class="legend-value">{{overview.reviewCount}}</text></view>
        <view class="legend-item"><text class="legend-dot legend-dot--orange"></text><text class="legend-label">未掌握</text><text class="legend-value">{{stats.wrongCount}}</text></view>
        <view class="legend-item"><text class="legend-dot legend-dot--gray"></text><text class="legend-label">无练习</text><text class="legend-value">{{overview.newCount}}</text></view>
      </view>
    </view>
  </view>

  <view class="assistant-strip" bindtap="goToAssistant">
    <image class="assistant-bg" src="/images/home-greeting-bg.png" mode="widthFix" />
    <view class="assistant-text">
      <text class="assistant-title">早上好呀！</text>
      <text class="assistant-desc">今天也要加油学习哦～</text>
    </view>
  </view>

  <view class="recommend-section">
    <text class="recommend-title">智能推荐</text>
    <view class="recommend-card" bindtap="goToImport">
      <view class="recommend-icon">⇲</view>
      <view class="recommend-copy">
        <text class="recommend-card-title">AI 结构化题库</text>
        <text class="recommend-card-desc">多格式资料一键导入，AI 解析结构化</text>
      </view>
    </view>
  </view>

  <!-- 选择题库弹窗（居中） -->
  <view class="modal-mask" wx:if="{{showBankPicker}}" catchtap="closeBankPicker">
    <view class="center-panel" catchtap="noop">
      <text class="center-title">选择题库</text>
      <view class="center-list">
        <view
          class="center-item {{item.name === currentBank ? 'center-item--active' : ''}}"
          wx:for="{{bankList}}"
          wx:key="name"
          data-name="{{item.name}}"
          bindtap="selectBank"
        >
          <view class="center-color" style="background:{{item.color}}"></view>
          <text class="center-name">{{item.name}}</text>
          <text class="center-check" wx:if="{{item.name === currentBank}}">✓</text>
        </view>
        <view class="center-empty" wx:if="{{bankList.length === 0}}">
          <text>暂未创建题库，请前往「题库」页创建</text>
        </view>
      </view>
    </view>
  </view>
</view>
