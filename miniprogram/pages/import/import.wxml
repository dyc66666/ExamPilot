<wxs module="U">
var countChecked = function(arr) {
  if (!arr || !arr.length) return 0;
  var n = 0;
  for (var i = 0; i < arr.length; i++) {
    if (arr[i]._checked) n++;
  }
  return n;
};
module.exports = { countChecked: countChecked };
</wxs>

<view class="import-page">

  <!-- 顶部导航 -->
  <ui-navbar title="题库" subtitle="导入复习资料" />

  <!-- 文件上传 -->
  <view class="upload-card" bindtap="chooseFile">
    <view class="upload-icon-wrap">
      <text class="upload-icon">+</text>
    </view>
    <text class="upload-title">导入复习资料</text>
    <text class="upload-desc">支持 PDF / Word（.docx）</text>
    <text class="upload-hint">AI 自动识别题目、选项、答案和知识点</text>
  </view>

  <!-- 解析中 -->
  <view class="card" wx:if="{{isParsing || isUploading}}">
    <view class="loading-box">
      <text class="loading-text">{{isUploading ? '上传并提取文字...' : (progress || 'AI 正在解析...')}}</text>
    </view>
  </view>

  <!-- 错误信息 -->
  <view class="card error-card" wx:if="{{errorMsg}}">
    <text class="error-title">解析失败</text>
    <text class="error-text">{{errorMsg}}</text>
  </view>

  <!-- 解析结果 -->
  <view class="card" wx:if="{{parsedQuestions.length > 0}}">
    <text class="card-title">核对确认 · {{parsedQuestions.length}} 题</text>
    <text class="card-subtitle">点击圆圈勾选，确认后入库</text>
    <view class="parsed-list">
      <view class="parsed-item {{item._checked ? '' : 'off'}}" wx:for="{{parsedQuestions}}" wx:key="id">
        <view class="parsed-row">
          <view class="parsed-check" bindtap="toggleQuestion" data-index="{{index}}">
            <text>{{item._checked ? 'V' : ''}}</text>
          </view>
          <text class="parsed-stem">{{item.stem}}</text>
        </view>
        <view class="parsed-meta">
          <text class="parsed-answer">答案：{{item.answer}}</text>
          <text class="parsed-tag" wx:if="{{item.knowledgePoint}}">{{item.knowledgePoint}}</text>
        </view>
      </view>
    </view>
    <button class="btn-save-all" bindtap="saveAllParsed">全部入库（{{U.countChecked(parsedQuestions)}} 题）</button>
  </view>

  <!-- 手动录入 -->
  <view class="card" wx:if="{{!showForm}}">
    <text class="card-title">手动录入</text>
    <button class="btn-secondary" bindtap="showForm">手动添加一道题</button>
  </view>

  <!-- 手动录入表单 -->
  <view class="card" wx:if="{{showForm}}">
    <text class="card-title">录入题目</text>
    <view class="form-group">
      <text class="form-label">题干</text>
      <textarea class="form-textarea" placeholder="请输入题目内容" value="{{newQuestion.stem}}" bindinput="onStemInput" />
    </view>
    <view class="form-group">
      <text class="form-label">选项</text>
      <view class="opt-row" wx:for="{{['A','B','C','D']}}" wx:key="*this" wx:for-index="idx">
        <text class="opt-letter">{{item}}</text>
        <input class="form-input" placeholder="选项 {{item}}" value="{{newQuestion.options[idx]}}" bindinput="onOptionInput" data-index="{{idx}}" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">正确答案</text>
      <input class="form-input" placeholder="如：A" value="{{newQuestion.answer}}" bindinput="onAnswerInput" />
    </view>
    <view class="form-group">
      <text class="form-label">解析</text>
      <textarea class="form-textarea short" placeholder="请输入解析" value="{{newQuestion.explanation}}" bindinput="onExplanationInput" />
    </view>
    <view class="form-group">
      <text class="form-label">知识点</text>
      <input class="form-input" placeholder="如：数据结构-二叉树" value="{{newQuestion.knowledgePoint}}" bindinput="onKnowledgeInput" />
    </view>
    <view class="btn-row">
      <button class="btn-cancel" bindtap="hideForm">取消</button>
      <button class="btn-confirm" bindtap="saveQuestion">保存入库</button>
    </view>
  </view>

  <!-- 已入库列表 -->
  <view class="card" wx:if="{{questions.length > 0}}">
    <view class="card-head">
      <text class="card-title">已入库（{{questions.length}} 题）</text>
      <text class="manage-btn" bindtap="toggleEditMode">{{editMode ? '取消' : '管理'}}</text>
    </view>
    <scroll-view class="q-scroll" scroll-y>
      <view class="question-item" wx:for="{{questions}}" wx:key="id">
        <view class="q-row">
          <view class="q-left">
            <view class="q-checkbox" wx:if="{{editMode}}" bindtap="toggleSelect" data-id="{{item.id}}">
              <text>{{item._selected ? 'V' : ''}}</text>
            </view>
            <text class="q-tag">{{item.knowledgePoint || '未分类'}}</text>
          </view>
          <text class="q-status {{item.status === 'mastered' ? 'ok' : ''}}" wx:if="{{!editMode}}">{{item.status === 'mastered' ? '已掌握' : '待测评'}}</text>
        </view>
        <text class="q-stem">{{item.stem}}</text>
      </view>
    </scroll-view>
    <view class="edit-bar" wx:if="{{editMode}}">
      <text class="select-all-btn" bindtap="selectAll">全选</text>
      <text class="select-count">已选 {{selectedCount}} 题</text>
      <text class="delete-btn" bindtap="deleteSelected">删除</text>
    </view>
  </view>

</view>
