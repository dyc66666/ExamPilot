<wxs module="U">
var countChecked = function(arr) {
  if (!arr || !arr.length) return 0;
  var n = 0;
  for (var i = 0; i < arr.length; i++) {
    if (arr[i]._checked) n++;
  }
  return n;
};
module.exports = { countChecked: countChecked };
</wxs>

<view class="import-page">

  <!-- 顶部导航 -->
  <ui-navbar title="题库" subtitle="导入复习资料" />

  <!-- 文件上传 -->
  <view class="upload-card" bindtap="chooseFile">
    <view class="upload-icon-wrap">
      <text class="upload-icon">+</text>
    </view>
    <text class="upload-title">导入复习资料</text>
    <text class="upload-desc">支持 PDF / Word（.docx）</text>
    <text class="upload-hint">AI 自动识别题目、选项、答案和知识点</text>
  </view>

  <!-- 解析中 -->
  <view class="card" wx:if="{{isParsing || isUploading}}">
    <view class="loading-box">
      <text class="loading-text">{{isUploading ? '上传并提取文字...' : (progress || 'AI 正在解析...')}}</text>
    </view>
  </view>

  <!-- 错误信息 -->
  <view class="card error-card" wx:if="{{errorMsg}}">
    <text class="error-title">解析失败</text>
    <text class="error-text">{{errorMsg}}</text>
  </view>

  <view class="card warning-card" wx:if="{{parseWarning}}">
    <text class="warning-title">需要核对</text>
    <text class="warning-text">{{parseWarning}}</text>
  </view>

  <!-- 解析结果 -->
  <view class="card" wx:if="{{parsedQuestions.length > 0}}">
    <view class="review-header">
      <text class="card-title">核对确认 · {{parsedQuestions.length}} 题</text>
      <text class="warn-summary" wx:if="{{warnCount > 0}}">{{warnCount}} 题需核对</text>
      <text class="duplicate-summary" wx:if="{{duplicateCount > 0}}">{{duplicateGroupCount}} 组重复</text>
    </view>
    <text class="card-subtitle">点击左侧勾选，重复题和异常题会置顶显示，可编辑后再入库</text>
    <view class="review-bar">
      <text class="link-btn" bindtap="selectAllParsed">全选</text>
      <text class="link-btn" bindtap="deselectAllParsed">取消全选</text>
      <text class="link-btn" wx:if="{{duplicateCount > 0}}" bindtap="deselectDuplicateParsed">取消重复题</text>
      <text class="link-btn danger" wx:if="{{duplicateCount > 0}}" bindtap="removeDuplicateParsed">删除重复项</text>
      <text>已选 {{U.countChecked(parsedQuestions)}} / {{parsedQuestions.length}}</text>
    </view>
    <view class="parsed-list">
      <view class="parsed-item {{item._checked ? '' : 'off'}} {{item._warn ? 'warn' : ''}} {{item._duplicate ? 'duplicate' : ''}}" wx:for="{{parsedQuestions}}" wx:key="id" bindtap="openParsedEditor" data-index="{{index}}">
        <view class="parsed-row">
          <view class="parsed-check" catchtap="toggleQuestion" data-index="{{index}}">
            <text>{{item._checked ? 'V' : ''}}</text>
          </view>
          <text class="parsed-stem">{{item.stem}}</text>
          <text class="parsed-edit">编辑</text>
        </view>
        <view class="parsed-meta">
          <text class="parsed-duplicate" wx:if="{{item._duplicate}}">{{item._duplicateLabel}}</text>
          <text class="parsed-answer">答案：{{item.answer}}</text>
          <text class="parsed-answer">选项：{{item.options.length}}</text>
          <text class="parsed-tag" wx:if="{{item.knowledgePoint}}">{{item.knowledgePoint}}</text>
        </view>
        <view class="parsed-warn" wx:if="{{item._warn}}">
          <text>⚠ {{item._warn}}</text>
        </view>
      </view>
    </view>
    <button class="btn-save-all" bindtap="saveAllParsed">确认入库（{{U.countChecked(parsedQuestions)}} 题）</button>
  </view>

  <view class="modal-mask" wx:if="{{showParsedEditor}}" catchtap="closeParsedEditor">
    <view class="modal-panel" catchtap="noop">
      <view class="modal-head">
        <text class="modal-title">编辑核对题目</text>
        <text class="modal-close" bindtap="closeParsedEditor">关闭</text>
      </view>
      <scroll-view class="modal-scroll" scroll-y>
        <view class="form-group">
          <text class="form-label">题干</text>
          <textarea class="form-textarea" value="{{activeParsedQuestion.stem}}" bindinput="onParsedStemInput" />
        </view>
        <view class="form-group">
          <text class="form-label">选项</text>
          <view class="opt-row parsed-opt-row" wx:for="{{activeParsedQuestion.options}}" wx:key="index" wx:for-index="idx">
            <text class="opt-letter">{{['A','B','C','D','E','F','G','H','I','J'][idx]}}</text>
            <input class="form-input" value="{{item}}" bindinput="onParsedOptionInput" data-index="{{idx}}" />
            <text class="remove-option" catchtap="removeParsedOption" data-index="{{idx}}">删</text>
          </view>
          <text class="add-option" bindtap="addParsedOption">+ 添加选项</text>
        </view>
        <view class="form-group">
          <text class="form-label">正确答案</text>
          <input class="form-input" placeholder="如：A 或 AC" value="{{activeParsedQuestion.answer}}" bindinput="onParsedAnswerInput" />
        </view>
        <view class="form-group">
          <text class="form-label">解析</text>
          <textarea class="form-textarea short" value="{{activeParsedQuestion.explanation}}" bindinput="onParsedExplanationInput" />
        </view>
        <view class="form-group">
          <text class="form-label">知识点</text>
          <input class="form-input" value="{{activeParsedQuestion.knowledgePoint}}" bindinput="onParsedKnowledgeInput" />
        </view>
      </scroll-view>
      <button class="btn-save-all modal-save" bindtap="saveParsedEdit">保存修改</button>
    </view>
  </view>

  <!-- 手动录入 -->
  <view class="card" wx:if="{{!showForm}}">
    <text class="card-title">手动录入</text>
    <button class="btn-secondary" bindtap="showForm">手动添加一道题</button>
  </view>

  <!-- 手动录入表单 -->
  <view class="card" wx:if="{{showForm}}">
    <text class="card-title">录入题目</text>
    <view class="form-group">
      <text class="form-label">题干</text>
      <textarea class="form-textarea" placeholder="请输入题目内容" value="{{newQuestion.stem}}" bindinput="onStemInput" />
    </view>
    <view class="form-group">
      <text class="form-label">选项</text>
      <view class="opt-row" wx:for="{{['A','B','C','D']}}" wx:key="*this" wx:for-index="idx">
        <text class="opt-letter">{{item}}</text>
        <input class="form-input" placeholder="选项 {{item}}" value="{{newQuestion.options[idx]}}" bindinput="onOptionInput" data-index="{{idx}}" />
      </view>
    </view>
    <view class="form-group">
      <text class="form-label">正确答案</text>
      <input class="form-input" placeholder="如：A" value="{{newQuestion.answer}}" bindinput="onAnswerInput" />
    </view>
    <view class="form-group">
      <text class="form-label">解析</text>
      <textarea class="form-textarea short" placeholder="请输入解析" value="{{newQuestion.explanation}}" bindinput="onExplanationInput" />
    </view>
    <view class="form-group">
      <text class="form-label">知识点</text>
      <input class="form-input" placeholder="如：数据结构-二叉树" value="{{newQuestion.knowledgePoint}}" bindinput="onKnowledgeInput" />
    </view>
    <view class="btn-row">
      <button class="btn-cancel" bindtap="hideForm">取消</button>
      <button class="btn-confirm" bindtap="saveQuestion">保存入库</button>
    </view>
  </view>

  <!-- 已入库列表 -->
  <view class="card" wx:if="{{questions.length > 0}}">
    <view class="card-head">
      <text class="card-title">已入库（{{questions.length}} 题）</text>
      <text class="manage-btn" bindtap="toggleEditMode">{{editMode ? '取消' : '管理'}}</text>
    </view>
    <scroll-view class="q-scroll" scroll-y>
      <view class="question-item" wx:for="{{questions}}" wx:key="id">
        <view class="q-row">
          <view class="q-left">
            <view class="q-checkbox" wx:if="{{editMode}}" bindtap="toggleSelect" data-id="{{item.id}}">
              <text>{{item._selected ? 'V' : ''}}</text>
            </view>
            <text class="q-tag">{{item.knowledgePoint || '未分类'}}</text>
          </view>
          <text class="q-status {{item.status === 'mastered' ? 'ok' : ''}}" wx:if="{{!editMode}}">{{item.status === 'mastered' ? '已掌握' : '待测评'}}</text>
        </view>
        <text class="q-stem">{{item.stem}}</text>
      </view>
    </scroll-view>
    <view class="edit-bar" wx:if="{{editMode}}">
      <text class="select-all-btn" bindtap="selectAll">全选</text>
      <text class="select-count">已选 {{selectedCount}} 题</text>
      <text class="delete-btn" bindtap="deleteSelected">删除</text>
    </view>
  </view>

</view>
