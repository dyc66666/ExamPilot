<wxs module="U">
var countChecked = function(arr) {
  if (!arr || !arr.length) return 0;
  var n = 0;
  for (var i = 0; i < arr.length; i++) {
    if (arr[i]._checked) n++;
  }
  return n;
};
module.exports = { countChecked: countChecked };
</wxs>

<view class="page page--tab import-page">
  <view wx:if="{{!showUploadPanel}}">
    <view class="bank-navbar">
      <view class="bank-heading">
        <text class="bank-title">我的题库</text>
        <text class="bank-subtitle">管理你的知识空间</text>
      </view>
      <view class="bank-actions">
        <view class="search-action">⌕</view>
        <view class="add-action" bindtap="openImportSheet">+ 新增/导入</view>
      </view>
    </view>

    <view class="recent-card" wx:if="{{bankDecks.length > 0}}">
      <text class="section-mini-title">最近学习</text>
      <view class="recent-row">
        <view class="deck-icon deck-color-0">▣</view>
        <view class="recent-main">
          <text class="recent-title">{{bankDecks[0].name}}</text>
          <text class="recent-subtitle">继续学习</text>
          <view class="recent-progress">
            <view class="recent-progress-fill" style="width: {{bankDecks[0].progress}}%;"></view>
          </view>
        </view>
        <text class="recent-arrow">›</text>
        <text class="recent-percent">{{bankDecks[0].progress}}%</text>
      </view>
    </view>

    <view class="deck-section">
      <view class="section-head">
        <text class="section-mini-title">全部题库（{{bankDecks.length}}）</text>
        <text class="manage-pill {{deckManageMode ? 'active' : ''}}" bindtap="toggleDeckManage">{{deckManageMode ? '完成' : '管理'}}</text>
      </view>

      <view class="deck-manage-bar" wx:if="{{deckManageMode}}">
        <text class="manage-pill" bindtap="selectAllDecks">{{selectedDeckCount == bankDecks.length ? '取消全选' : '全选'}}</text>
        <text class="manage-count">已选 {{selectedDeckCount}} 个</text>
        <text class="manage-pill" bindtap="favoriteSelectedDecks">收藏</text>
        <text class="manage-pill danger" bindtap="deleteSelectedDecks">删除</text>
      </view>

      <view class="empty-bank" wx:if="{{bankDecks.length == 0}}">
        <view class="empty-folder">▣</view>
        <text class="empty-title">还没有题库</text>
        <text class="empty-desc">点击右上角新增/导入，上传 PDF 或 Word 自动整理题目</text>
        <button class="primary-pill" bindtap="openImportSheet">新增/导入</button>
      </view>

      <view class="deck-list" wx:else>
        <view class="deck-card {{item._selected ? 'selected' : ''}}" wx:for="{{bankDecks}}" wx:key="name" data-name="{{item.name}}" bindtap="toggleDeckSelect">
          <view class="deck-select {{item._selected ? 'checked' : ''}}" wx:if="{{deckManageMode}}">
            <text>{{item._selected ? '✓' : ''}}</text>
          </view>
          <view class="deck-icon {{item.colorClass}}">▣</view>
          <view class="deck-info">
            <view class="deck-title-line">
              <text class="deck-title">{{item.name}}</text>
              <text class="deck-fav" wx:if="{{item.favorite}}">★</text>
            </view>
            <view class="deck-meta-row">
              <text class="deck-meta">{{item.totalText}}</text>
              <text class="deck-progress-text">掌握率</text>
              <text class="deck-percent {{item.progress < 50 ? 'low' : ''}}">{{item.progress}}%</text>
            </view>
          </view>
          <view class="deck-right">
            <text class="deck-more">•••</text>
            <view class="deck-time-row">
              <text class="deck-time">{{item.timeText}}</text>
              <text class="deck-chevron">›</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  <!-- ===== 手动录入弹窗 ===== -->
</view>
  <view class="sheet-mask" wx:if="{{showForm}}" catchtap="hideForm">
    <view class="form-sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="form-sheet-scroll">
        <text class="form-sheet-title">手动录入</text>
        <view class="form-group">
          <text class="form-label">题干</text>
          <textarea class="form-textarea" placeholder="请输入题目内容" value="{{newQuestion.stem}}" bindinput="onStemInput" />
        </view>
        <view class="form-group">
          <text class="form-label">选项</text>
          <view class="opt-row" wx:for="{{['A','B','C','D']}}" wx:key="*this" wx:for-index="idx">
            <text class="opt-letter">{{item}}</text>
            <input class="form-input" placeholder="选项 {{item}}" value="{{newQuestion.options[idx]}}" bindinput="onOptionInput" data-index="{{idx}}" adjust-position="{{false}}" />
          </view>
        </view>
        <view class="form-group">
          <text class="form-label">正确答案</text>
          <input class="form-input" placeholder="如：A" value="{{newQuestion.answer}}" bindinput="onAnswerInput" />
        </view>
        <view class="form-group">
          <text class="form-label">解析</text>
          <textarea class="form-textarea short" placeholder="请输入解析" value="{{newQuestion.explanation}}" bindinput="onExplanationInput" />
        </view>
        <view class="form-group">
          <text class="form-label">知识点</text>
          <input class="form-input" placeholder="如：数据结构-二叉树" value="{{newQuestion.knowledgePoint}}" bindinput="onKnowledgeInput" />
        </view>
        <view class="btn-row">
          <button class="btn-cancel" bindtap="hideForm">取消</button>
          <button class="btn-confirm" bindtap="saveQuestion">保存入库</button>
        </view>
      </view>
    </view>
  </view>

  <view class="sheet-mask" wx:if="{{showCreateBankPanel}}" catchtap="closeCreateBankPanel">
    <view class="create-sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="create-body">
        <view class="create-folder-icon">
          <view class="folder-back"></view>
          <view class="folder-front"></view>
        </view>

        <text class="create-title-center">新建题库</text>

        <view class="create-form-group">
          <text class="create-label">题库名称</text>
          <view class="name-input-wrap">
            <input
              class="name-input"
              placeholder="请输入题库名称"
              maxlength="20"
              value="{{newBankName}}"
              bindinput="onNewBankNameInput"
              focus="{{true}}"
              confirm-type="done"
              bindconfirm="confirmCreateBank"
            />
            <text class="name-count">{{newBankNameLen || 0}}/20</text>
          </view>
        </view>

        <view class="create-form-group">
          <text class="create-label">选择颜色</text>
          <view class="color-picker">
            <view
              wx:for="{{bankColors}}"
              wx:key="index"
              class="color-dot {{selectedColorIndex == index ? 'checked' : ''}}"
              style="background: {{item}};"
              data-index="{{index}}"
              bindtap="selectColor"
            >
              <text class="check-icon" wx:if="{{selectedColorIndex == index}}">✓</text>
            </view>
          </view>
        </view>

        <button
          class="btn-create-bank"
          disabled="{{!canCreateBank}}"
          bindtap="confirmCreateBank"
        >创建题库</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showUploadPanel}}">
    <view class="import-navbar">
      <view class="back-action" bindtap="closeUploadPanel">‹</view>
      <view class="import-step">
        <text class="step-count">{{importSuccess ? '4/4' : (parsedQuestions.length ? '3/4' : (showMaterialDecision ? '2/4' : (isParsing ? '2/4' : '1/4')))}}</text>
        <text>{{importSuccess ? '导入完成' : (parsedQuestions.length ? '核对入库' : (showMaterialDecision ? '确认方式' : (isParsing ? 'AI 判断中' : '上传文件')))}}</text>
      </view>
      <text class="import-title">导入资料</text>
      <view class="nav-spacer"></view>
    </view>

    <view class="upload-card" bindtap="chooseFile" wx:if="{{!importSuccess && !isParsing && !isUploading && !showMaterialDecision && parsedQuestions.length === 0}}">
      <view class="upload-cloud">☁</view>
      <text class="upload-title">点击选择 PDF / Word 文件上传</text>
      <text class="upload-desc">当前支持 PDF / Word（.docx），AI 会先判断资料类型</text>
      <text class="upload-hint">文件大小不超过 20MB</text>
    </view>

    <view class="recognizing-card" wx:if="{{isParsing || isUploading}}">
      <view class="robot-face">AI</view>
      <text class="recognizing-title">{{isUploading ? '正在上传文件...' : '正在识别题目内容...'}}</text>
      <text class="recognizing-desc">{{progress || 'AI 正在分析文档，请稍候'}}</text>
      <view class="recognizing-track"><view class="recognizing-fill" style="width: {{parseProgress}}%;"></view></view>
    </view>

    <view class="card error-card" wx:if="{{errorMsg}}">
      <text class="error-title">解析失败</text>
      <text class="error-text">{{errorMsg}}</text>
    </view>

    <view class="card warning-card" wx:if="{{parseWarning}}">
      <text class="warning-title">需要核对</text>
      <text class="warning-text">{{parseWarning}}</text>
    </view>

    <view class="material-decision-card" wx:if="{{!importSuccess && showMaterialDecision && materialAnalysis}}">
      <view class="material-decision-head">
        <view>
          <text class="card-title">AI 已完成资料判断</text>
          <text class="card-subtitle">请确认接下来按哪种方式处理</text>
        </view>
        <view class="material-confidence">{{materialAnalysis.confidence}}%</view>
      </view>
      <view class="material-type-row">
        <text class="material-type-pill">{{materialAnalysis.materialTypeLabel}}</text>
        <text class="material-subject">{{materialAnalysis.subject}}</text>
      </view>
      <text class="material-summary">{{materialAnalysis.summary}}</text>
      <view class="material-info-grid">
        <view class="material-info-item">
          <text class="material-info-label">考试目标</text>
          <text class="material-info-value">{{materialAnalysis.examGoal}}</text>
        </view>
        <view class="material-info-item">
          <text class="material-info-label">文件</text>
          <text class="material-info-value">{{materialAnalysis.fileName}}</text>
        </view>
      </view>
      <view class="material-section" wx:if="{{materialAnalysis.chapters.length}}">
        <text class="material-section-title">识别到的章节</text>
        <view class="material-tags">
          <text class="material-tag" wx:for="{{materialAnalysis.chapters}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      <view class="material-section" wx:if="{{materialAnalysis.keyPoints.length}}">
        <text class="material-section-title">可能考点</text>
        <view class="material-tags">
          <text class="material-tag key" wx:for="{{materialAnalysis.keyPoints}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      <view class="material-evidence" wx:if="{{materialAnalysis.questionEvidence}}">
        <text>{{materialAnalysis.questionEvidence}}</text>
      </view>
      <view class="generate-level-section">
        <view class="generate-level-head">
          <text class="material-section-title">自由出题等级</text>
          <text class="generate-level-hint">系统会按考点自动估算题量</text>
        </view>
        <view class="generate-level-options">
          <view class="generate-level-option {{generateLevel == item.value ? 'active' : ''}}" wx:for="{{generateLevelOptions}}" wx:key="value" data-level="{{item.value}}" bindtap="chooseGenerateLevel">
            <view class="generate-level-title-row">
              <text class="generate-level-title">{{item.title}}</text>
              <text class="generate-level-badge">{{item.perPoint}}</text>
            </view>
            <text class="generate-level-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
      <view class="material-actions">
        <button class="material-action-primary" data-mode="generate" bindtap="chooseMaterialMode">提炼考点，自由出题</button>
        <button class="material-action-secondary" data-mode="organize" bindtap="chooseMaterialMode">按文档题目整理入库</button>
      </view>
    </view>

    <view class="success-card" wx:if="{{importSuccess}}">
      <view class="success-mark-wrap">
        <text class="confetti confetti-a">•</text>
        <text class="confetti confetti-b">•</text>
        <text class="confetti confetti-c">•</text>
        <text class="confetti confetti-d">•</text>
        <view class="success-mark">✓</view>
      </view>
      <text class="success-title">导入成功！</text>
      <text class="success-desc">已成功导入 {{importSavedCount}} 道题目</text>
      <button class="success-primary" bindtap="viewImportedBank">查看题库</button>
      <button class="success-secondary" bindtap="continueImport">继续导入</button>
    </view>

    <view class="review-card" wx:if="{{!importSuccess && parsedQuestions.length > 0}}">
      <view class="review-header">
        <view>
          <text class="card-title">识别完成</text>
          <text class="card-subtitle">共识别 {{parsedQuestions.length}} 道题目，请核对后保存</text>
        </view>
        <view class="recognized-badge">{{U.countChecked(parsedQuestions)}}/{{parsedQuestions.length}}</view>
      </view>
      <view class="review-tags">
        <text class="warn-summary" wx:if="{{warnCount > 0}}">{{warnCount}} 题异常</text>
        <text class="duplicate-summary" wx:if="{{duplicateCount > 0}}">{{duplicateGroupCount}} 组重复</text>
      </view>
      <view class="bank-picker">
        <view class="bank-picker-head">
          <text class="bank-picker-title">选择入库题库</text>
          <text class="bank-picker-subtitle">确认后题目会保存到所选题库</text>
        </view>
        <scroll-view class="bank-picker-scroll" scroll-x="true" wx:if="{{bankDecks.length > 0}}">
          <view class="bank-choice {{!useNewImportBank && importBankName == item.name ? 'active' : ''}}" wx:for="{{bankDecks}}" wx:key="name" data-name="{{item.name}}" bindtap="chooseImportBank">
            <text>{{item.name}}</text>
          </view>
        </scroll-view>
        <view class="bank-choice {{!useNewImportBank && importBankName == '未分类题库' ? 'active' : ''}}" wx:else data-name="未分类题库" bindtap="chooseImportBank">
          <text>未分类题库</text>
        </view>
        <view class="bank-choice new {{useNewImportBank ? 'active' : ''}}" bindtap="useNewBankForImport">
          <text>+ 新建题库</text>
        </view>
        <input class="bank-name-input" wx:if="{{useNewImportBank}}" placeholder="请输入新题库名称" value="{{importNewBankName}}" bindinput="onImportNewBankInput" />
      </view>
      <view class="review-bar">
        <text class="link-btn" bindtap="selectAllParsed">全选</text>
        <text class="link-btn" bindtap="deselectAllParsed">取消全选</text>
        <text class="link-btn" wx:if="{{duplicateCount > 0}}" bindtap="deselectDuplicateParsed">重复题保留一份</text>
        <text class="link-btn danger" wx:if="{{duplicateCount > 0}}" bindtap="removeDuplicateParsed">删除重复项</text>
      </view>
      <view class="parsed-list">
        <view class="parsed-item {{item._checked ? '' : 'off'}} {{item._warn ? 'warn' : ''}} {{item._duplicate ? 'duplicate' : ''}}" wx:for="{{parsedQuestions}}" wx:key="id" bindtap="openParsedEditor" data-index="{{index}}">
          <view class="parsed-row">
            <view class="parsed-check" catchtap="toggleQuestion" data-index="{{index}}">
              <text>{{item._checked ? '✓' : ''}}</text>
            </view>
            <text class="parsed-stem">{{item.stem}}</text>
            <text class="parsed-edit">编辑</text>
          </view>
          <view class="parsed-meta">
            <text class="parsed-duplicate" wx:if="{{item._duplicate}}">{{item._duplicateLabel}}</text>
            <text class="parsed-answer">答案：{{item.answer}}</text>
            <text class="parsed-answer">选项：{{item.options.length}}</text>
            <text class="parsed-tag" wx:if="{{item.knowledgePoint}}">{{item.knowledgePoint}}</text>
          </view>
          <view class="parsed-warn" wx:if="{{item._warn}}">
            <text>⚠ {{item._warn}}</text>
          </view>
        </view>
      </view>
      <button class="btn-save-all" bindtap="saveAllParsed">确认入库（{{U.countChecked(parsedQuestions)}} 题）</button>
    </view>
  </view>

  <view class="sheet-mask" wx:if="{{showImportSheet}}" catchtap="closeImportSheet">
    <view class="import-sheet" catchtap="noop">
      <view class="sheet-handle"></view>
      <view class="sheet-option" bindtap="createNewBank">
        <view class="sheet-icon icon-folder"></view>
        <view>
          <text class="sheet-title">新建题库</text>
          <text class="sheet-desc">创建空白题库文件夹</text>
        </view>
      </view>
      <view class="sheet-option" bindtap="openUploadPanel">
        <view class="sheet-icon icon-import"></view>
        <view>
          <text class="sheet-title">导入资料</text>
          <text class="sheet-desc">AI 先判断资料类型，再选择整理题库或自由出题</text>
        </view>
      </view>
      <view class="sheet-option" bindtap="openCameraCapture">
        <view class="sheet-icon icon-camera"></view>
        <view>
          <text class="sheet-title">拍照识别</text>
          <text class="sheet-desc">拍照识别题目，AI 自动整理</text>
        </view>
      </view>
      <view class="sheet-option" bindtap="openManualEntry">
        <view class="sheet-icon icon-manual"></view>
        <view>
          <text class="sheet-title">手动录入</text>
          <text class="sheet-desc">手动输入题目和答案</text>
        </view>
      </view>
      <view class="sheet-cancel" bindtap="closeImportSheet">取消</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showParsedEditor}}" catchtap="closeParsedEditor">
    <view class="modal-panel" catchtap="noop">
      <view class="modal-head">
        <text class="modal-title">编辑核对题目</text>
        <text class="modal-close" bindtap="closeParsedEditor">关闭</text>
      </view>
      <scroll-view class="modal-scroll" scroll-y>
        <view class="form-group">
          <text class="form-label">题干</text>
          <textarea class="form-textarea" value="{{activeParsedQuestion.stem}}" bindinput="onParsedStemInput" />
        </view>
        <view class="form-group">
          <text class="form-label">选项</text>
          <view class="opt-row parsed-opt-row" wx:for="{{activeParsedQuestion.options}}" wx:key="index" wx:for-index="idx">
            <text class="opt-letter">{{['A','B','C','D','E','F','G','H','I','J'][idx]}}</text>
            <input class="form-input" value="{{item}}" bindinput="onParsedOptionInput" data-index="{{idx}}" />
            <text class="remove-option" catchtap="removeParsedOption" data-index="{{idx}}">删</text>
          </view>
          <text class="add-option" bindtap="addParsedOption">+ 添加选项</text>
        </view>
        <view class="form-group">
          <text class="form-label">正确答案</text>
          <input class="form-input" placeholder="如：A 或 AC" value="{{activeParsedQuestion.answer}}" bindinput="onParsedAnswerInput" />
        </view>
        <view class="form-group">
          <text class="form-label">解析</text>
          <textarea class="form-textarea short" value="{{activeParsedQuestion.explanation}}" bindinput="onParsedExplanationInput" />
        </view>
        <view class="form-group">
          <text class="form-label">知识点</text>
          <input class="form-input" value="{{activeParsedQuestion.knowledgePoint}}" bindinput="onParsedKnowledgeInput" />
        </view>
      </scroll-view>
      <button class="btn-save-all modal-save" bindtap="saveParsedEdit">保存修改</button>
    </view>
  </view>
</view>
