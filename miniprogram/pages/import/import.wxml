<view class="page page--tab import-page">
  <ui-navbar title="题库" subtitle="导入题库" />

  <ui-card title="导入题库" subtitle="支持多种格式，AI 智能解析结构化">
    <view class="upload-panel" bindtap="showForm">
      <view class="upload-icon">⇧</view>
      <text class="upload-title">点击上传或手动录入题目</text>
      <text class="upload-desc">支持 PDF / 图片 / Word / PPT / Excel</text>
    </view>
  </ui-card>

  <view class="section-tight">
    <ui-card title="导入说明">
      <view class="notice-box"><text class="notice-dot"></text><text class="notice-text">建议清晰的题目和答案区域，提高解析准确率。</text></view>
      <view class="notice-box"><text class="notice-dot"></text><text class="notice-text">导入后可进入学习页确认题目内容。</text></view>
    </ui-card>
  </view>

  <view class="section-tight" wx:if="{{showAddForm}}">
    <ui-card title="手动录入题目" subtitle="用于快速补充单题">
      <view class="form-stack">
        <ui-input label="题干" placeholder="请输入题目内容" value="{{newQuestion.stem}}" multiline="{{true}}" bind:input="onStemInput" />
        <view class="option-field" wx:for="{{optionLabels}}" wx:key="label">
          <text class="option-label">{{item.label}}</text>
          <ui-input placeholder="选项 {{item.label}}" value="{{newQuestion.options[index]}}" data-index="{{index}}" bind:input="onOptionInput" />
        </view>
        <ui-input label="正确答案" placeholder="如：A" value="{{newQuestion.answer}}" bind:input="onAnswerInput" />
        <ui-input label="解析" placeholder="请输入解析" value="{{newQuestion.explanation}}" multiline="{{true}}" bind:input="onExplanationInput" />
        <ui-input label="知识点" placeholder="如：高等数学 · 导数" value="{{newQuestion.knowledgePoint}}" bind:input="onKnowledgeInput" />
        <view class="form-actions">
          <ui-button variant="ghost" block="{{true}}" bind:tap="hideForm">取消</ui-button>
          <ui-button variant="primary" block="{{true}}" bind:tap="saveQuestion">保存入库</ui-button>
        </view>
      </view>
    </ui-card>
  </view>

  <view class="section-tight" wx:if="{{questions.length > 0}}">
    <ui-card title="已入库题目" subtitle="{{questions.length}} 道题目已准备学习">
      <view class="question-list">
        <view class="question-row" wx:for="{{questions}}" wx:key="id">
          <view class="question-row__top"><text class="tag">{{item.knowledgePoint || '未分类'}}</text><text class="caption">{{item.status === 'mastered' ? '已掌握' : '待学习'}}</text></view>
          <text class="question-row__stem">{{item.stem}}</text>
        </view>
      </view>
    </ui-card>
  </view>
</view>
