.import-page {
  background:
    radial-gradient(circle at 18% 0%, rgba(121, 142, 255, 0.14), transparent 34%),
    radial-gradient(circle at 90% 12%, rgba(180, 103, 255, 0.12), transparent 36%),
    #F7F8FF;
}

.bank-navbar,
.import-navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding-top: calc(env(safe-area-inset-top) + 32rpx);
  margin-bottom: 28rpx;
}

.bank-title,
.import-title {
  display: block;
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 800;
}

.bank-subtitle {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.bank-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.icon-action {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.86);
  box-shadow: var(--shadow-card);
  color: var(--text-primary);
  font-size: 32rpx;
  line-height: 64rpx;
  text-align: center;
}

.add-action,
.primary-pill {
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5E7BFF, #A65CFF);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  box-shadow: 0 12rpx 28rpx rgba(94, 123, 255, 0.28);
}

.recent-card,
.manual-card,
.question-manage-card,
.review-card,
.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(255,255,255,0.72);
  border-radius: 28rpx;
  background: rgba(255,255,255,0.88);
  box-shadow: var(--shadow-card);
}

.section-mini-title {
  display: block;
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 700;
}

.recent-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 22rpx;
}

.deck-icon {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  border-radius: 18rpx;
  color: #fff;
  font-size: 30rpx;
  line-height: 64rpx;
  text-align: center;
  box-shadow: 0 10rpx 22rpx rgba(78, 123, 255, 0.18);
}

.deck-color-0 { background: linear-gradient(135deg, #7E6BFF, #A65CFF); }
.deck-color-1 { background: linear-gradient(135deg, #4E7BFF, #5FC6FF); }
.deck-color-2 { background: linear-gradient(135deg, #FFB443, #FF8B3D); }
.deck-color-3 { background: linear-gradient(135deg, #35D6A7, #4E7BFF); }
.deck-color-4 { background: linear-gradient(135deg, #FF7A5F, #FFB443); }

.recent-main {
  flex: 1;
  min-width: 0;
}

.recent-title,
.deck-title {
  display: block;
  overflow: hidden;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-subtitle,
.deck-meta,
.empty-desc {
  display: block;
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.recent-progress,
.deck-progress {
  height: 8rpx;
  margin-top: 12rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #EEF1F8;
}

.recent-progress-fill,
.deck-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4E7BFF, #A65CFF);
}

.recent-percent,
.deck-percent {
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 700;
}

.summary-strip {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 34rpx;
}

.summary-item {
  min-height: 128rpx;
  padding: 24rpx 12rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.82);
  box-shadow: var(--shadow-card);
  text-align: center;
}

.summary-value {
  display: block;
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 800;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.grid-dot {
  color: var(--primary);
  font-size: 28rpx;
}

.deck-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.deck-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.88);
  box-shadow: var(--shadow-card);
}

.question-manage-card {
  margin-top: 28rpx;
}

.manage-btn {
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 700;
}

.q-scroll {
  max-height: 520rpx;
  overflow-y: auto;
}

.question-item {
  padding: 22rpx 0;
  border-bottom: 2rpx solid #F0F2F7;
}

.question-item:last-child {
  border-bottom: none;
}

.q-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 10rpx;
}

.q-left {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 12rpx;
}

.q-checkbox {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 42rpx;
  border-radius: 50%;
  background: #EEF3FF;
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 800;
}

.q-tag {
  max-width: 360rpx;
  overflow: hidden;
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  background: #EEF3FF;
  color: var(--primary);
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.q-status {
  flex-shrink: 0;
  color: #F59E0B;
  font-size: 22rpx;
  font-weight: 700;
}

.q-status.ok {
  color: var(--success);
}

.q-stem {
  display: block;
  overflow: hidden;
  color: var(--text-primary);
  font-size: 27rpx;
  line-height: 1.5;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid #F0F2F7;
}

.select-all-btn {
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 700;
}

.select-count {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.delete-btn {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #EF4444;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.deck-info {
  flex: 1;
  min-width: 0;
}

.deck-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 18rpx;
}

.deck-more {
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1;
}

.empty-bank {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 68rpx 36rpx;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.84);
  box-shadow: var(--shadow-card);
  text-align: center;
}

.empty-folder {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #7E6BFF, #A65CFF);
  color: #fff;
  font-size: 48rpx;
  line-height: 112rpx;
  text-align: center;
}

.empty-title {
  display: block;
  margin-top: 24rpx;
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 800;
}

.empty-desc {
  max-width: 460rpx;
  margin-bottom: 28rpx;
  line-height: 1.5;
}

.back-action {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  color: var(--text-primary);
  font-size: 48rpx;
  line-height: 60rpx;
  text-align: center;
}

.import-step {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: var(--primary);
  font-size: 24rpx;
}

.step-count {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #EEF3FF;
  font-weight: 700;
}

.nav-spacer {
  width: 64rpx;
}

.upload-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 520rpx;
  margin-top: 42rpx;
  padding: 60rpx 36rpx;
  border: 3rpx dashed rgba(126, 107, 255, 0.34);
  border-radius: 28rpx;
  background: rgba(255,255,255,0.74);
  box-shadow: var(--shadow-card);
  text-align: center;
}

.upload-cloud {
  color: #8B6CFF;
  font-size: 118rpx;
  line-height: 1;
}

.upload-title {
  display: block;
  margin-top: 26rpx;
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 700;
}

.upload-desc,
.upload-hint {
  display: block;
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.recognizing-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 560rpx;
  padding: 60rpx 36rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.82);
  box-shadow: var(--shadow-card);
  text-align: center;
}

.robot-face {
  width: 132rpx;
  height: 132rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #2B325B, #7E6BFF);
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 132rpx;
  text-align: center;
  box-shadow: 0 18rpx 42rpx rgba(94, 123, 255, 0.25);
}

.recognizing-title {
  display: block;
  margin-top: 42rpx;
  color: var(--text-primary);
  font-size: 34rpx;
  font-weight: 800;
}

.recognizing-desc {
  display: block;
  margin-top: 12rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.recognizing-track {
  width: 78%;
  height: 12rpx;
  margin-top: 42rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #E8ECF8;
}

.recognizing-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4E7BFF, #A65CFF);
  transition: width 180ms ease;
}

.success-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 650rpx;
  padding: 70rpx 42rpx 54rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 18rpx 48rpx rgba(35, 38, 72, 0.08);
}

.success-mark-wrap {
  position: relative;
  width: 188rpx;
  height: 168rpx;
  margin-top: 8rpx;
}

.success-mark {
  position: absolute;
  left: 34rpx;
  top: 26rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7D95FF, #A65CFF);
  color: #FFFFFF;
  font-size: 62rpx;
  font-weight: 800;
  line-height: 120rpx;
  text-align: center;
  box-shadow: 0 20rpx 46rpx rgba(126, 107, 255, 0.32);
}

.confetti {
  position: absolute;
  color: #8B68FF;
  font-size: 26rpx;
  line-height: 1;
}

.confetti-a { left: 10rpx; top: 34rpx; color: #61C9FF; }
.confetti-b { right: 16rpx; top: 24rpx; color: #FF80B5; }
.confetti-c { left: 42rpx; bottom: 8rpx; color: #FFB23F; }
.confetti-d { right: 38rpx; bottom: 18rpx; color: #68D391; }

.success-title {
  margin-top: 20rpx;
  color: #202333;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.success-desc {
  margin-top: 14rpx;
  color: #7A8396;
  font-size: 25rpx;
}

.success-primary,
.success-secondary {
  width: 100%;
  height: 82rpx;
  margin-top: 48rpx;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 82rpx;
  text-align: center;
}

.success-primary {
  background: linear-gradient(135deg, #5E7BFF, #A65CFF);
  color: #FFFFFF;
  box-shadow: 0 14rpx 32rpx rgba(94, 123, 255, 0.24);
}

.success-secondary {
  margin-top: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #5E5BFF;
  box-shadow: 0 8rpx 24rpx rgba(35, 38, 72, 0.05);
}

.card-title {
  display: block;
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 800;
}

.card-subtitle {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.review-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.recognized-badge {
  min-width: 100rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #EEF3FF;
  color: var(--primary);
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.review-tags,
.review-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 22rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.bank-picker {
  margin-top: 24rpx;
  padding: 22rpx;
  border: 2rpx solid #EEF1F8;
  border-radius: 22rpx;
  background: rgba(248, 250, 255, 0.86);
}

.bank-picker-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.bank-picker-title {
  color: #202333;
  font-size: 27rpx;
  font-weight: 800;
}

.bank-picker-subtitle {
  color: #8A91A3;
  font-size: 22rpx;
}

.bank-picker-scroll {
  width: 100%;
  white-space: nowrap;
}

.bank-choice {
  display: inline-flex;
  align-items: center;
  max-width: 320rpx;
  height: 58rpx;
  margin: 0 14rpx 14rpx 0;
  padding: 0 22rpx;
  border: 2rpx solid #E6EAF5;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #667085;
  font-size: 24rpx;
  font-weight: 700;
  vertical-align: top;
}

.bank-choice text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bank-choice.active {
  border-color: rgba(94, 123, 255, 0.48);
  background: linear-gradient(135deg, rgba(94, 123, 255, 0.14), rgba(166, 92, 255, 0.16));
  color: #4E5BFF;
}

.bank-choice.new {
  margin-bottom: 0;
  color: #5E5BFF;
}

.bank-name-input {
  height: 72rpx;
  padding: 0 22rpx;
  border: 2rpx solid #E8ECF3;
  border-radius: 18rpx;
  background: #FFFFFF;
  color: #202333;
  font-size: 26rpx;
}

.import-bank-create {
  margin-top: 16rpx;
}

.import-bank-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

.import-bank-action {
  width: auto;
  min-width: 144rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 24rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.import-bank-action::after {
  border: 0;
}

.import-bank-action.secondary {
  background: #FFFFFF;
  color: #667085;
  border: 2rpx solid #E3E7F0;
}

.import-bank-action.primary {
  background: #5E7BFF;
  color: #FFFFFF;
}

.import-bank-action.primary[disabled] {
  background: #DCE3F7;
  color: #9AA5C4;
}

.warn-summary {
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  background: rgba(255, 69, 58, 0.1);
  color: #DC2626;
  font-size: 22rpx;
  font-weight: 700;
}

.duplicate-summary,
.parsed-duplicate {
  padding: 6rpx 16rpx;
  border-radius: 10rpx;
  background: #FEF3C7;
  color: #B45309;
  font-size: 22rpx;
  font-weight: 700;
}

.link-btn {
  color: var(--primary);
  font-weight: 700;
}

.link-btn.danger {
  color: #EF4444;
}

.parsed-list {
  max-height: 560rpx;
  margin-top: 18rpx;
  overflow-y: auto;
}

.parsed-item {
  padding: 22rpx 0;
  border-bottom: 2rpx solid #F0F2F7;
}

.parsed-item:last-child {
  border-bottom: none;
}

.parsed-item.off {
  opacity: 0.72;
}

.parsed-item.warn {
  padding: 18rpx 10rpx;
  border-radius: 14rpx;
  background: #FFF1F1;
}

.parsed-item.duplicate {
  padding: 18rpx 10rpx;
  border-radius: 14rpx;
  background: #FFFBEB;
}

.parsed-item.duplicate.warn {
  background: #FFF1F1;
}

.parsed-row {
  display: flex;
  align-items: flex-start;
}

.parsed-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 48rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #EEF3FF;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 800;
}

.parsed-stem {
  flex: 1;
  min-width: 0;
  color: var(--text-primary);
  font-size: 27rpx;
  line-height: 1.55;
}

.parsed-edit {
  margin-left: 14rpx;
  color: var(--primary);
  font-size: 24rpx;
  flex-shrink: 0;
}

.parsed-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 12rpx 0 0 64rpx;
}

.parsed-answer {
  color: var(--success);
  font-size: 23rpx;
  font-weight: 700;
}

.parsed-tag {
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
  background: #EEF3FF;
  color: var(--primary);
  font-size: 22rpx;
}

.parsed-warn {
  margin: 10rpx 0 0 64rpx;
  color: #DC2626;
  font-size: 22rpx;
  font-weight: 700;
}

.btn-save-all {
  width: 100%;
  min-height: 88rpx;
  margin-top: 28rpx;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5E7BFF, #A65CFF);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 14rpx 30rpx rgba(94, 123, 255, 0.26);
}

.sheet-mask,
.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: flex-end;
  background: rgba(25, 28, 54, 0.42);
}

.import-sheet,
.modal-panel {
  width: 100%;
  max-height: 88vh;
  padding: 24rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: rgba(255,255,255,0.96);
  box-shadow: 0 -18rpx 52rpx rgba(35, 38, 72, 0.18);
}

.sheet-handle {
  width: 64rpx;
  height: 8rpx;
  margin: 0 auto 24rpx;
  border-radius: 999rpx;
  background: #CED4E5;
}

.sheet-option {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-height: 132rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
  border: 2rpx solid #EEF1F8;
  border-radius: 24rpx;
  background: #fff;
}

.sheet-icon {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 64rpx;
  border-radius: 18rpx;
}

.icon-folder {
  background: url(data:image/svg+xml;base64,) no-repeat center / 34rpx 34rpx, linear-gradient(135deg, #7E6BFF, #A65CFF);
}

.icon-import {
  background: url(data:image/svg+xml;base64,) no-repeat center / 34rpx 34rpx, linear-gradient(135deg, #7E6BFF, #A65CFF);
}

.icon-camera {
  background: url(data:image/svg+xml;base64,) no-repeat center / 34rpx 34rpx, linear-gradient(135deg, #7E6BFF, #A65CFF);
}

.icon-manual {
  background: url(data:image/svg+xml;base64,) no-repeat center / 34rpx 34rpx, linear-gradient(135deg, #7E6BFF, #A65CFF);
}

.sheet-title {
  display: block;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 800;
}

.sheet-desc {
  display: block;
  margin-top: 8rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.sheet-cancel {
  height: 76rpx;
  border-radius: 999rpx;
  background: #F7F8FA;
  color: var(--text-primary);
