/* ========== 新建题库底部弹窗 ========== */
.create-sheet {
  width: 100%;
  max-height: 85vh;
  padding: 24rpx 32rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: rgba(255,255,255,0.97);
  box-shadow: 0 -18rpx 52rpx rgba(35, 38, 72, 0.18);
}

.create-body {
  margin-top: 8rpx;
}

.create-title-center {
  display: block;
  color: #202333;
  font-size: 33rpx;
  font-weight: 800;
  text-align: center;
  margin-bottom: 28rpx;
}

/* 紫色文件夹图标 */
.create-folder-icon {
  position: relative;
  width: 140rpx;
  height: 120rpx;
  margin: 0 auto 36rpx;
}

.folder-back {
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 96rpx;
  height: 52rpx;
  border-radius: 14rpx 14rpx 6rpx 6rpx;
  background: linear-gradient(145deg, #A78BFA, #8B5CF6);
  z-index: 0;
}

.folder-front {
  position: absolute;
  left: 8rpx;
  bottom: 0;
  width: 144rpx;
  height: 110rpx;
  border-radius: 22rpx 18rpx 18rpx 18rpx;
  background: linear-gradient(155deg, #C4B5FD, #A78BFA);
  box-shadow:
    0 12rpx 36rpx rgba(139, 92, 246, 0.28),
    inset 0 -8rpx 20rpx rgba(124, 58, 237, 0.08);
  z-index: 1;
}

/* 表单区域 */
.create-form-group {
  margin-bottom: 32rpx;
}

.create-label {
  display: block;
  color: #202333;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.name-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.name-input {
  flex: 1;
  height: 88rpx;
  padding: 0 120rpx 0 28rpx;
  border: 2rpx solid #E8ECF3;
  border-radius: 22rpx;
  background: #fff;
  color: #202333;
  font-size: 28rpx;
}

.name-count {
  position: absolute;
  right: 26rpx;
  color: #98A2B3;
  font-size: 24rpx;
  pointer-events: none;
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.color-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(35, 38, 72, 0.1);
  transition: transform 180ms ease;
  position: relative;
}

.color-dot.checked {
  transform: scale(1.15);
  box-shadow: 0 0 0 4rpx rgba(255,255,255,0.9), 0 6rpx 20rpx rgba(35, 38, 72, 0.15);
}

.check-icon {
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  text-shadow: 0 1rpx 3rpx rgba(0,0,0,0.25);
}

/* 创建按钮 */
.btn-create-bank {
  width: 100%;
  height: 92rpx;
  margin-top: 36rpx;
  border: none;
  border-radius: 46rpx;
  background: linear-gradient(135deg, #7E6BFF, #A65CFF);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  text-align: center;
  box-shadow: 0 14rpx 34rpx rgba(126, 107, 255, 0.30);
}

.btn-create-bank[disabled] {
  opacity: 0.45;
  box-shadow: none;
}

/* 空状态复用已有样式 */

