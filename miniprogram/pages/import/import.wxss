.import-page { background: var(--background); }
.upload-panel { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:240rpx; border:2rpx dashed var(--border); border-radius:32rpx; background:#FBFCFF; }
.upload-icon { display:flex; align-items:center; justify-content:center; width:88rpx; height:88rpx; border:4rpx solid var(--primary); border-radius:999rpx; color:var(--primary); font-size:44rpx; font-weight:600; }
.upload-title { display:block; margin-top:24rpx; color:var(--text-primary); font-size:28rpx; font-weight:500; }
.upload-desc { display:block; margin-top:8rpx; color:var(--text-secondary); font-size:24rpx; }
.notice-box { display:flex; align-items:flex-start; margin-bottom:16rpx; padding:20rpx; border-radius:24rpx; background:#F7F9FE; }
.notice-dot { width:10rpx; height:10rpx; margin-top:14rpx; margin-right:14rpx; border-radius:999rpx; background:var(--primary); }
.notice-text { flex:1; color:var(--text-secondary); font-size:26rpx; line-height:1.55; }
.form-stack { display:grid; gap:24rpx; }
.option-field { display:grid; grid-template-columns:56rpx 1fr; align-items:end; gap:16rpx; }
.option-label { display:flex; align-items:center; justify-content:center; height:96rpx; border-radius:18rpx; background:#EEF3FF; color:var(--primary); font-size:28rpx; font-weight:700; }
.form-actions { display:grid; grid-template-columns:1fr 1fr; gap:16rpx; }
.question-list { display:grid; gap:16rpx; }
.question-row { padding:24rpx; border:2rpx solid var(--border); border-radius:28rpx; background:#fff; }
.question-row__top { display:flex; align-items:center; justify-content:space-between; margin-bottom:16rpx; }
.question-row__stem { display:block; overflow:hidden; color:var(--text-primary); font-size:28rpx; font-weight:500; text-overflow:ellipsis; white-space:nowrap; }
