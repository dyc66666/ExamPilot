.container { padding-bottom: 40rpx; }

.banner {
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  padding: 50rpx 40rpx;
  text-align: center;
}
.banner-num { font-size: 72rpx; font-weight: 700; color: #fff; display: block; }
.banner-label { font-size: 26rpx; color: rgba(255,255,255,0.8); display: block; margin-top: 8rpx; }

.card { background: #fff; border-radius: 16rpx; padding: 32rpx; margin: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.card-title { font-size: 30rpx; font-weight: 700; display: block; margin-bottom: 24rpx; }

.import-options { display: flex; flex-wrap: wrap; gap: 16rpx; }
.import-option {
  width: calc(50% - 8rpx);
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 32rpx 0;
  text-align: center;
}
.import-icon { font-size: 40rpx; display: block; margin-bottom: 10rpx; }

.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 12rpx; }
.form-input { background: #F5F7FA; border-radius: 10rpx; padding: 20rpx; font-size: 28rpx; }
.form-textarea { background: #F5F7FA; border-radius: 10rpx; padding: 20rpx; font-size: 28rpx; min-height: 120rpx; }
.form-textarea.short { min-height: 80rpx; }

.option-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.option-label {
  width: 50rpx; height: 50rpx; background: #EEF2FF;
  color: #4F46E5; border-radius: 8rpx;
  text-align: center; line-height: 50rpx; font-weight: 700; margin-right: 16rpx; flex-shrink: 0;
}
.option-row .form-input { flex: 1; }

.form-buttons { display: flex; gap: 16rpx; margin-top: 32rpx; }
.btn-cancel {
  flex: 1; background: #F5F5F5; border: none; border-radius: 12rpx;
  padding: 20rpx; font-size: 28rpx; text-align: center;
}
.btn-save { flex: 1; padding: 20rpx; border: none; }

.question-item { padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.question-item:last-child { border-bottom: none; }
.q-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.q-tag { background: #EEF2FF; color: #4F46E5; font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 8rpx; }
.q-status { font-size: 22rpx; color: #F59E0B; }
.q-status.green { color: #10B981; }
.q-stem { font-size: 28rpx; color: #333; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block; }
