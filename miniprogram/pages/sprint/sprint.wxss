.sprint-page {
  background: var(--background);
}

.mode-list {
  display: grid;
  gap: 16rpx;
}

.mode-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 148rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  background: #F7F9FE;
  transition: all 200ms ease-in-out;
}

.mode-card--green {
  background: rgba(52, 199, 89, 0.10);
}

.mode-card--blue {
  background: #F3F6FF;
}

.mode-card--purple {
  background: #F7F2FF;
}

.mode-card--active {
  border-color: var(--primary);
  background: #FFFFFF;
}

.mode-title {
  display: block;
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 600;
}

.mode-desc,
.mode-effect {
  display: block;
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
}

.mode-effect {
  color: var(--text-primary);
  font-weight: 500;
}

.mode-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: var(--primary);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.mode-footer {
  display: grid;
  gap: 20rpx;
  margin-top: 32rpx;
}

.empty-hint {
  margin-top: 24rpx;
  padding: 0 16rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
  text-align: center;
}

.sprint-status {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.question-stem {
  display: block;
  margin-top: 28rpx;
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.65;
}

.options-list {
  display: grid;
  gap: 16rpx;
  margin-top: 28rpx;
}

.option-item {
  display: grid;
  grid-template-columns: 28rpx 40rpx 1fr;
  align-items: center;
  min-height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  background: #FFFFFF;
  transition: all 200ms ease-in-out;
}

.option-radio {
  width: 16rpx;
  height: 16rpx;
  border: 2rpx solid #B9C0CC;
  border-radius: 999rpx;
}

.option-label {
  color: var(--text-secondary);
  font-size: 26rpx;
  font-weight: 600;
}

.option-text {
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 500;
}

.option-item--selected {
  border-color: #DCE6FF;
  background: #EEF3FF;
}

.option-item--selected .option-radio {
  border-color: var(--primary);
  background: var(--primary);
}

.option-item--correct {
  border-color: rgba(52, 199, 89, 0.36);
  background: rgba(52, 199, 89, 0.10);
}

.option-item--wrong {
  border-color: rgba(255, 69, 58, 0.36);
  background: rgba(255, 69, 58, 0.08);
}

.answer-panel {
  margin-top: 32rpx;
}

.answer-result {
  padding: 24rpx;
  border-radius: 24rpx;
}

.answer-result--correct {
  background: rgba(52, 199, 89, 0.10);
}

.answer-result--wrong {
  background: rgba(255, 69, 58, 0.08);
}

.answer-result__title {
  display: block;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.answer-result__desc {
  display: block;
  margin-top: 6rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.explanation-box {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #F7F9FE;
}

.explanation-label {
  display: block;
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 600;
}

.explanation-text {
  display: block;
  margin-top: 10rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.6;
}

.quiz-actions {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 16rpx;
  margin-top: 40rpx;
}
