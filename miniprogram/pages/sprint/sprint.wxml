<view class="page sprint-page">
  <view wx:if="{{!isStarted}}">
    <ui-navbar title="冲刺" subtitle="选择冲刺模式" back="{{true}}" bind:back="goBack" />

    <ui-card title="选择冲刺模式" subtitle="根据你的掌握情况，生成专属学习方案">
      <view class="mode-list">
        <view
          wx:for="{{modeCards}}"
          wx:key="value"
          class="mode-card {{selectedMode === item.value ? 'mode-card--active' : ''}} mode-card--{{item.tone}}"
          data-value="{{item.value}}"
          bindtap="selectMode"
        >
          <view>
            <text class="mode-title">{{item.title}}</text>
            <text class="mode-desc">{{item.desc}}</text>
            <text class="mode-effect">预计提升 {{item.effect}}</text>
          </view>
          <view class="mode-check">{{selectedMode === item.value ? '✓' : item.icon}}</view>
        </view>
      </view>

      <view class="mode-footer">
        <text class="caption">当前错题 {{questions.length}} 道</text>
        <ui-button variant="primary" block="{{true}}" disabled="{{questions.length === 0}}" bind:tap="startSprint">
          开始冲刺
        </ui-button>
      </view>
    </ui-card>

    <view class="empty-hint" wx:if="{{questions.length === 0}}">
      <text>暂无错题。完成测评后，可在这里生成个性化冲刺。</text>
    </view>
  </view>

  <view wx:if="{{isStarted && currentQuestion}}">
    <ui-navbar title="{{currentModeTitle}}" subtitle="错题冲刺" back="{{true}}" bind:back="stopSprint" />

    <ui-card>
      <view class="sprint-status">
        <text class="caption">{{progressText}}</text>
        <text class="caption">剩余 {{remainingCount}} 题</text>
      </view>

      <view class="progress-track">
        <view class="progress-fill {{progressClass}}"></view>
      </view>

      <text class="question-stem">{{currentIndex + 1}}. {{currentQuestion.stem}}</text>

      <view class="options-list">
        <view
          wx:for="{{currentQuestion.optionItems}}"
          wx:key="label"
          class="option-item {{selectedAnswer === item.label ? 'option-item--selected' : ''}} {{isSubmitted && item.label === currentQuestion.answer ? 'option-item--correct' : ''}} {{isSubmitted && selectedAnswer === item.label && !isCorrect ? 'option-item--wrong' : ''}}"
          data-value="{{item.label}}"
          bindtap="selectAnswer"
        >
          <view class="option-radio"></view>
          <text class="option-label">{{item.label}}</text>
          <text class="option-text">{{item.text}}</text>
        </view>
      </view>

      <view class="answer-panel" wx:if="{{isSubmitted}}">
        <view class="answer-result {{isCorrect ? 'answer-result--correct' : 'answer-result--wrong'}}">
          <text class="answer-result__title">{{isCorrect ? '答对了' : '答错了'}}</text>
          <text class="answer-result__desc">{{isCorrect ? '此题已从错题本移除' : '此题保留在错题本，稍后继续巩固'}}</text>
        </view>

        <view class="explanation-box" wx:if="{{currentQuestion.explanation}}">
          <text class="explanation-label">解析</text>
          <text class="explanation-text">{{currentQuestion.explanation}}</text>
        </view>
      </view>

      <view class="quiz-actions">
        <ui-button variant="ghost" bind:tap="stopSprint">退出</ui-button>
        <ui-button variant="primary" disabled="{{!selectedAnswer}}" bind:tap="handlePrimaryAction">
          {{isSubmitted ? nextButtonText : '提交'}}
        </ui-button>
      </view>
    </ui-card>
  </view>
</view>
