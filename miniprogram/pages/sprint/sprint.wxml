<view class="page sprint-page">
  <!-- 开始页 -->
  <view wx:if="{{!isStarted}}">
    <ui-navbar title="冲刺" subtitle="选择冲刺模式" back="{{true}}" bind:back="goBack" />

    <ui-card title="选择冲刺模式" subtitle="根据你的掌握情况，生成专属学习方案">
      <view class="mode-list">
        <view
          wx:for="{{modeCards}}"
          wx:key="value"
          class="mode-card {{selectedMode === item.value ? 'mode-card--active' : ''}} mode-card--{{item.tone}}"
          data-value="{{item.value}}"
          bindtap="selectMode"
        >
          <view>
            <text class="mode-title">{{item.title}}</text>
            <text class="mode-desc">{{item.desc}}</text>
            <text class="mode-effect">预计提升 {{item.effect}}</text>
          </view>
          <view class="mode-check">{{selectedMode === item.value ? '✓' : item.icon}}</view>
        </view>
      </view>

      <view class="mode-footer">
        <text class="caption">当前错题 {{questions.length}} 道</text>
        <ui-button variant="primary" block="{{true}}" disabled="{{questions.length === 0}}" bind:tap="startSprint">
          开始冲刺
        </ui-button>
      </view>
    </ui-card>

    <view class="empty-hint" wx:if="{{questions.length === 0}}">
      <text>暂无错题。完成测评后，可在这里生成个性化冲刺。</text>
    </view>
  </view>

  <!-- 答题页 -->
  <view class="quiz-body" wx:if="{{isStarted && currentQuestion}}">
    <ui-navbar title="{{currentModeTitle}}" subtitle="{{progressText}}" back="{{true}}" bind:back="goBack" />
    <view class="progress-track"><view class="progress-fill {{progressClass}}"></view></view>

    <view class="quiz-content">
      <view class="quiz-meta">
        <text class="qtype-tag {{currentQuestion.qtype === '多选题' ? 'qtype-multi' : 'qtype-single'}}">{{currentQuestion.qtype}}</text>
        <text class="tag tag--success">{{currentQuestion.knowledgePoint || '未归类'}}</text>
      </view>
      <text class="question-stem">{{currentIndex + 1}}. {{currentQuestion.stem}}</text>

      <!-- 选项 -->
      <view class="options-list">
        <view wx:for="{{currentQuestion.optionItems}}" wx:key="label" wx:for-item="opt" wx:for-index="i"
          class="option-item {{opt._sel ? 'option-item--selected' : ''}} {{opt._correct ? 'option-item--correct' : ''}} {{opt._wrong ? 'option-item--wrong' : ''}}"
          bindtap="toggleAnswer" data-value="{{opt.label}}">
          <view class="opt-mark">{{currentQuestion.qtype === '多选题' ? (opt._sel ? '&#10003;' : '&#9744;') : ''}}</view>
          <text class="option-label">{{opt.label}}</text>
          <text class="option-text">{{opt.text}}</text>
        </view>
      </view>

      <!-- 提交按钮 -->
      <view class="submit-row" wx:if="{{!isSubmitted}}">
        <button class="submit-btn" bindtap="submitAnswer">提交答案</button>
      </view>

      <!-- 结果面板 -->
      <view wx:if="{{isSubmitted}}" class="answer-panel">
        <view class="answer-result {{isCorrect ? 'answer-result--correct' : 'answer-result--wrong'}}">
          <text class="answer-result-title">{{isCorrect ? '回答正确' : '回答错误'}}</text>
          <text class="answer-result-desc">{{isCorrect ? '此题已从错题本移除' : '此题保留在错题本，稍后继续巩固'}}</text>
        </view>
        <view class="explanation-box" wx:if="{{!isCorrect || currentQuestion.explanation}}">
          <text class="explanation-label">解析</text>
          <text class="explanation-text" wx:if="{{explanationLoading}}">AI 正在生成解析...</text>
          <text class="explanation-text" wx:else>{{currentQuestion.explanation || '暂无解析'}}</text>
        </view>
        <view class="next-btn" bindtap="nextQuestion">下一题</view>
      </view>
    </view>

    <!-- 底部：不会 -->
    <view class="quiz-bottom" wx:if="{{!isSubmitted}}">
      <view class="bottom-btn bottom-btn--skip" bindtap="markAsDontKnow">不会，看答案</view>
    </view>
  </view>
</view>
